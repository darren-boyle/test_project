  // If already a header map object
  if (
    sheetOrHeaders &&
    typeof sheetOrHeaders === 'object' &&
    typeof sheetOrHeaders.getRange !== 'function' &&
    typeof sheetOrHeaders.getLastColumn !== 'function'
  ) {
    return sheetOrHeaders;
