    Exact_Address: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Exact_Address)),
    Postcode: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Postcode)),
    London_Borough: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.London_Borough)),
    Notes: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Notes))
  };

  // Validation: Exact GPS requires both coordinates
  if (exactGpsChecked === true && (!record.Latitude || !record.Longitude)) {
