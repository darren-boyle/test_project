/**
 * Generic next sequential ID helper.
 * Example: nextSequentialId_(sheet, 1, 'CASE', 4) => CASE0001
 * idColIndex is 1-based because it is used directly with getRange().
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {number} idColIndex
 * @param {string} prefix
 * @param {number} padLength
 * @return {string}
 */
function nextSequentialId_(sheet, idColIndex, prefix, padLength) {
  if (!sheet) throw new Error('nextSequentialId_: sheet is required.');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) {
    return prefix + String(1).padStart(padLength, '0');
  }

  const values = sheet
    .getRange(2, idColIndex, lastRow - 1, 1)
    .getValues()
    .flat();

  let maxNum = 0;
  values.forEach(v => {
    const s = String(v || '').trim();
    if (s.startsWith(prefix)) {
      const n = parseInt(s.substring(prefix.length), 10);
      if (!isNaN(n) && n > maxNum) maxNum = n;
    }
  });

  return prefix + String(maxNum + 1).padStart(padLength, '0');
}

/**
 * Build an array row from headers and an object.
 * Missing keys become blank strings.
 * @param {Array<string>} headers
 * @param {Object} obj
 * @return {Array<any>}
 */
const buildRowByHeaders_ = (headers, obj) => 
  headers.map(h => {
    const key = String(h || '').trim();
    return Object.prototype.hasOwnProperty.call(obj, key) ? obj[key] : '';
  });

/**
 * Write/update an existing row by headers without overwriting unspecified fields.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {number} rowNumber
 * @param {Array<string>} headers
 * @param {Object} obj
 */
function writeObjectToRowByHeaders_(sheet, rowNumber, headers, obj) {
  const existing = sheet.getRange(rowNumber, 1, 1, headers.length).getValues()[0];

  const updated = headers.map((h, i) => {
    const key = String(h || '').trim();
    return Object.prototype.hasOwnProperty.call(obj, key) ? obj[key] : existing[i];
  });

  sheet.getRange(rowNumber, 1, 1, headers.length).setValues([updated]);
}

/**
 * Append a new row by headers and object.
 * Returns the new last row number.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {Array<string>} headers
 * @param {Object} obj
 * @return {number}
 */
function appendObjectByHeaders_(sheet, headers, obj) {
  const row = buildRowByHeaders_(headers, obj);
  sheet.appendRow(row);
  return sheet.getLastRow();
}

/**
 * Append a new row using a sheet + header map + object.
 * Safe when column order changes.
 * headerMap is expected to be 0-based.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {Object} headerMap
 * @param {Object} rowObj
 */
function appendRowByHeaders_(sheet, headerMap, rowObj) {
  if (!sheet) throw new Error('appendRowByHeaders_: missing sheet');
  if (!headerMap || typeof headerMap !== 'object') {
    throw new Error(`appendRowByHeaders_: invalid headerMap for sheet ${sheet.getName()}`);
  }
  if (!rowObj || typeof rowObj !== 'object') {
    throw new Error(`appendRowByHeaders_: invalid rowObj for sheet ${sheet.getName()}`);
  }

  const lastCol = sheet.getLastColumn();
  if (lastCol < 1) {
    throw new Error(`appendRowByHeaders_: sheet has no columns: ${sheet.getName()}`);
  }

  const row = new Array(lastCol).fill('');
  Object.keys(rowObj).forEach(key => {
    const idx = headerMap[key];
    if (idx !== undefined && idx >= 0 && idx < lastCol) {
      row[idx] = rowObj[key];
    }
  });

  sheet.appendRow(row);
}

/**
 * Normalise free text for comparisons.
 * @param {any} v
