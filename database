        Victim_ID: victimId,
        Image_URL: imageUrl,
        Caption: caption,
        Credit: credit,
        Image_Type: imageType || 'Victim',
        Public_Source_Only: publicSource,
        Notes: ''
      };

      if (existingRow !== -1) {
        writeObjectToRowByHeaders_(imagesSheet, existingRow, iHeaders, obj);
      } else {
        const newRow = new Array(iHeaders.length).fill('');

