      function() { return fn(sheet, caseId, selectedVictimLabel); },
      function() { return fn(caseId, selectedVictimLabel, sheet); },
      function() { return fn(caseId, sheet, selectedVictimLabel); },
      function() { return fn(caseId, sheet); },
      function() { return fn(caseId); },
      function() { return fn(sheet); }
