function saveNewCaseEntry() {
  const entry = getUserEntrySheet_();
  if (!entry) throw new Error('Missing entry sheet for current user');

  try {
    setSearchStatusSafe_(entry, 'Saving new case...');

    const casesInfo = save_getSheetAndHeaders_('Cases');
    const casesSheet = casesInfo.sheet;
    const headers = casesInfo.headers;
    const headerMap = casesInfo.map; // 0-based

    if (headerMap['Case_ID'] === undefined) {
      throw new Error('Cases sheet missing Case_ID header');
    }

    // Generate next Case_ID using 0-based header map helper
    const caseId = save_nextIdByPrefix_(casesSheet, headerMap, 'Case_ID', 'CASE');

    // Build new case object from form
    const rowObj = readNewCaseForSave_(entry, caseId, headers);

    // Append new row to Cases
    appendObjectByHeaders_(casesSheet, headers, rowObj);

   // Save related tables (victim/location/source/etc.)
    const relatedResult = saveNewCaseRelatedTables_(entry, caseId);

    // Write newly created Location_ID back into Cases if that header exists
    if (relatedResult && relatedResult.locationId) {
      const caseLocationUpdate = {};

      setIfHeaderExists_(caseLocationUpdate, headers, 'Location_ID', relatedResult.locationId);
      setIfHeaderExists_(caseLocationUpdate, headers, 'Primary_Location_ID', relatedResult.locationId);

      if (Object.keys(caseLocationUpdate).length) {
        const caseIdCol = headerMap['Case_ID'];
        const caseRowNumber = findRowByExactId_(casesSheet, caseIdCol + 1, caseId);

        if (caseRowNumber) {
          writeObjectToRowByHeaders_(casesSheet, caseRowNumber, headers, caseLocationUpdate);
        }
      }
    }

    // Keep current state in sync
    entry.getRange(getNewCaseFieldMap_().currentCaseId).setValue(caseId);
    // Build preview row using existing Search helper
    writePreviewRow_(entry, {
      caseId: caseId,
      victim: '',
      date: rowObj['Date_of_Murder'] || '',
      policeForce: rowObj['Police_Force_At_Time'] || '',
      townCity: rowObj['Town/City'] || rowObj['Town_City'] || '',
      londonBorough: rowObj['London_Borough'] || '',
