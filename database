const ENTRY_SHEET_FALLBACK = 'New_Case_Entry_User_1';

/**
 * Resolves the active user interface worksheet view.
 * Prioritizes the sheet currently selected by the user.
 * Fallback handles workspace-restricted environments gracefully.
 * * @return {GoogleAppsScript.Spreadsheet.Sheet}
 */
function getUserEntrySheet_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // 1. Primary Strategy: Check if the user is currently looking at a valid entry sheet
  const activeSheet = ss.getActiveSheet();
  if (activeSheet) {
    const activeName = String(activeSheet.getName() || '').trim();
    // Safely pull validation array directly from your 00_Config master setup
    if (getAllEntrySheetNames_().indexOf(activeName) !== -1) {
      return activeSheet;
    }
  }

  // 2. Secondary Strategy: Safe contextual email parsing
  try {
    const userEmail = String(Session.getActiveUser().getEmail() || '')
      .trim()
      .toLowerCase();

    if (userEmail) {
      // Direct assignment map for distributed data entry targets
      const userTabMap = {
        'darren.boyle@dailymail.co.uk': 'New_Case_Entry_User_1',
        'rhodri.morgan@dailymail.co.uk': 'New_Case_Entry_User_2'
      };

      const mappedName = userTabMap[userEmail];
      if (mappedName) {
        const mappedSheet = ss.getSheetByName(mappedName);
        if (mappedSheet) return mappedSheet;
      }
    }
  } catch (authError) {
    // Log auth restriction internally, don't break the user's workflow
    console.warn("Email context access restricted under current macro AuthMode: " + authError.message);
  }

  // 3. Final Fallback: Return standard master default container
  const fallbackSheet = ss.getSheetByName(ENTRY_SHEET_FALLBACK);
  if (!fallbackSheet) {
    throw new Error(`Fatal Environment Failure: Default data entry tab "${ENTRY_SHEET_FALLBACK}" could not be located.`);
  }
  return fallbackSheet;
}

