/**
 * Optimised banner updates using a single range block 
 * instead of independent cell background operations.
 */
function setModeBanner_(entry, message, colour) {
  const sh = entry || getUserEntrySheet_();
  if (!sh) return;

  // Since F4:G4 and H4:N4 are contiguous, we grab F4:N4 in one go
  const totalBannerRange = sh.getRange('F4:N4');
  
  if (colour) {
