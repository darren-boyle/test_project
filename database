/**
 * Build a clean victim display name.
 *
 * Supports:
 *   buildVictimName_(rowObj)
 *   buildVictimName_(rowArray, headerMap)
 *
 * Expected fields:
 *   Victim
 *   Victim_First_Name
 *   Victim_Last_Name
 *   Victim_Alias
 */
function buildVictimName_(rowOrObj, headerMap) {
  if (!rowOrObj) return '';

  let victim = '';
  let first = '';
  let last = '';
  let alias = '';

  // Object style:
  // { Victim: '', Victim_First_Name: '', Victim_Last_Name: '', Victim_Alias: '' }
  if (!Array.isArray(rowOrObj) && typeof rowOrObj === 'object') {
    victim = String(rowOrObj.Victim || '').trim();
    first = String(rowOrObj.Victim_First_Name || '').trim();
    last = String(rowOrObj.Victim_Last_Name || '').trim();
    alias = String(rowOrObj.Victim_Alias || '').trim();
  }

  // Row array + headerMap style
  else if (Array.isArray(rowOrObj) && headerMap && typeof headerMap === 'object') {
    const row = rowOrObj;

    function getVal_(headerName) {
      const idx = headerMap[headerName];
      return idx === undefined ? '' : String(row[idx] || '').trim();
    }

    victim = getVal_('Victim');
    first = getVal_('Victim_First_Name');
    last = getVal_('Victim_Last_Name');
    alias = getVal_('Victim_Alias');
  }

  if (victim) {
    if (alias && normalise_(alias) !== normalise_(victim)) {
      return victim + ' (' + alias + ')';
    }
    return victim;
  }

  const fullName = [first, last].filter(Boolean).join(' ').trim();

  if (fullName) {
    if (alias && normalise_(alias) !== normalise_(fullName)) {
      return fullName + ' (' + alias + ')';
    }
    return fullName;
  }

  if (alias) return alias;

  return '';
}

/**
 * Convenience helper when you already have separate first/last/alias parts.
 */
function buildVictimNameFromParts_(first, last, alias) {
  first = String(first || '').trim();
  last = String(last || '').trim();
  alias = String(alias || '').trim();

  const fullName = [first, last].filter(Boolean).join(' ').trim();

  if (fullName) {
    if (alias && normalise_(alias) !== normalise_(fullName)) {
      return fullName + ' (' + alias + ')';
    }
    return fullName;
  }

  return alias || '';
}

/**
 * Parse a victim picker value such as:
 *   "June Sheasby || CASE0004"
 * or:
 *   "VIC0001 - June Sheasby"
 * into clean parts.
 */
function parseVictimPickerValue_(rawValue) {
  const raw = String(rawValue || '').trim();

  const out = {
    raw: raw,
    victimName: '',
    caseId: '',
    victimId: ''
  };

  if (!raw) return out;

  // Pattern: "Victim Name || CASE0004"
  if (raw.indexOf('||') !== -1) {
    const parts = raw.split('||').map(function(s) {
      return String(s || '').trim();
    });

    out.victimName = parts[0] || '';
    out.caseId = parts[1] || '';
    return out;
  }

  // Pattern: "VIC0001 - Victim Name"
  const dashMatch = raw.match(/^([A-Z0-9_-]+)\s*-\s*(.+)$/i);
  if (dashMatch) {
    out.victimId = String(dashMatch[1] || '').trim();
    out.victimName = String(dashMatch[2] || '').trim();
  }

  // Extract case id if present anywhere
  const caseMatch = raw.match(/\bCASE\d+\b/i);
  if (caseMatch) {
    out.caseId = String(caseMatch[0] || '').trim();
  }

  return out;
}

