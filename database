function saveNewCaseRelatedTables_(entry, caseId) {
  const result = {
    victims: 0,
    locations: 0,
    locationId: '',
    sources: 0,
    events: 0,
    images: 0
  };

  // ---------------------------
  // VICTIM
  // ---------------------------
  if (shouldCreateNewVictimRow_(entry)) {
    result.victims += appendNewVictimRow_(entry, caseId);
  }

  // ---------------------------
  // LOCATION
  // ---------------------------
  if (shouldCreateNewLocationRow_(entry)) {
    const locResult = appendNewLocationRow_(entry, caseId);

    if (locResult && typeof locResult === 'object') {
      result.locations += Number(locResult.created || 0);
      result.locationId = String(locResult.locationId || '').trim();
    } else {
      result.locations += Number(locResult || 0);
    }
  }

  // ---------------------------
  // SOURCE
  // ---------------------------
  if (shouldCreateNewSourceRow_(entry)) {
    result.sources += appendNewSourceRow_(entry, caseId);
  }

  // ---------------------------
  // EVENT
  // ---------------------------
  if (shouldCreateNewEventRow_(entry)) {
    result.events += appendNewEventRow_(entry, caseId);
  }

  // ---------------------------
  // IMAGE
  // ---------------------------
  if (typeof shouldCreateNewImageRow_ === 'function' && shouldCreateNewImageRow_(entry)) {
    result.images += appendNewImageRow_(entry, caseId);
  }

  return result;
