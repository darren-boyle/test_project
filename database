/*********************************
 * 17_DeleteCase.gs
 * Delete the currently loaded case and all linked rows
 *********************************/

function runDeleteLoadedCase() {
  return deleteLoadedCase_();
}

function deleteLoadedCase_() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = getUserEntrySheet_();
  if (!sheet) throw new Error('Missing entry sheet for current user');

  const caseId = getCurrentCaseId_(null, sheet);
  if (!caseId) {
    throw new Error('No loaded Case_ID found. Load a case first before deleting.');
  }

  const confirm = ui.alert(
    'Delete loaded case?',
    'This will permanently delete ' + caseId +
      ' from Cases, Victims, Locations, Sources, Case_Events, Related_Stories, Case_Images and Case_Live_Enquiries.\n\n' +
      'This cannot be undone.',
    ui.ButtonSet.YES_NO
  );

  if (confirm !== ui.Button.YES) {
    return;
  }

  const lock = LockService.getDocumentLock();
  if (!lock.tryLock(10000)) {
    throw new Error('Another operation is already running. Please try again.');
  }

  try {
    setFormModeBanner_('BUSY', 'Deleting loaded case...');
    setSearchStatusSafe_(sheet, 'Deleting ' + caseId + '...');

    // Read Cases row first so we can fallback to Location_ID if needed
    const casesInfo = delete_getSheetAndRows_('Cases');
    const caseRowNum = delete_findFirstRowByCaseId_(casesInfo, caseId);
    if (!caseRowNum) {
      throw new Error('Could not find Cases row for ' + caseId);
    }

    const caseRowObj = delete_readRowObject_(casesInfo, caseRowNum);
    const locationId = delete_getValue_(caseRowObj, ['Location_ID']);

    // Delete linked rows first, then the Cases row last
    delete_rowsByCaseId_('Victims', caseId);
    delete_rowsByCaseId_('Sources', caseId);
    delete_rowsByCaseId_('Case_Events', caseId);
    delete_rowsByCaseId_('Related_Stories', caseId);
    delete_rowsByCaseId_('Case_Images', caseId);
    delete_rowsByCaseId_('Case_Live_Enquiries', caseId);

    // Locations: prefer Case_ID, fallback to Location_ID if needed
    const deletedLocationRows = delete_rowsByCaseId_('Locations', caseId);
    if (deletedLocationRows === 0 && locationId) {
      delete_rowsByHeaderValue_('Locations', ['Location_ID'], locationId);
    }

    // Finally delete the case row itself
    delete_rowsByCaseId_('Cases', caseId);

    // Audit log
    const sourceFormName = sheet.getName();
    logAuditIfAvailable_({
      actionType: 'CASE_DELETED',
      recordId: caseId,
      sourceForm: sourceFormName,
      notes: 'Deleted via deleteLoadedCase_'
    });

    // Rebuild dependent search index
    try {
      rebuildCaseSearchIndex();
    } catch (indexErr) {
      Logger.log('Delete completed but search index rebuild failed: ' + indexErr);
    }

    // Clean up UI using the canonical new clear flow
    runClearEntryForm();
    setFormModeBanner_('NEW', 'Case deleted – ready for new case');
    setSearchStatusSafe_(sheet, 'Deleted ' + caseId + ' successfully');

    ui.alert('Deleted ' + caseId + ' successfully.');

    return caseId;

  } finally {
    lock.releaseLock();
  }
}


/* =========================================================
 * HELPERS
 * ========================================================= */

function delete_getSheetAndRows_(sheetName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) throw new Error('Missing sheet: ' + sheetName);

  const data = sheet.getDataRange().getValues();
  const headers = data.length
    ? data[0].map(function(h) { return String(h || '').trim(); })
    : [];

  return {
    sheet: sheet,
    headers: headers,
    data: data
  };
}

function delete_norm_(value) {
  return String(value || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]/g, '');
}

function delete_findHeaderIndex_(headers, possibleNames) {
  const normalisedHeaders = headers.map(delete_norm_);
  for (let i = 0; i < possibleNames.length; i++) {
    const idx = normalisedHeaders.indexOf(delete_norm_(possibleNames[i]));
    if (idx !== -1) return idx;
  }
  return -1;
}

function delete_findFirstRowByCaseId_(sheetInfo, caseId) {
  const idx = delete_findHeaderIndex_(sheetInfo.headers, ['Case_ID', 'Case ID']);
  if (idx === -1) return 0;

  for (let r = 1; r < sheetInfo.data.length; r++) {
    if (String(sheetInfo.data[r][idx] || '').trim() === String(caseId).trim()) {
      return r + 1; // actual sheet row number
    }
  }

  return 0;
}

function delete_readRowObject_(sheetInfo, rowNum) {
  const rowValues = sheetInfo.sheet
    .getRange(rowNum, 1, 1, sheetInfo.headers.length)
    .getValues()[0];

  const obj = {};
  sheetInfo.headers.forEach(function(h, i) {
    obj[h] = rowValues[i];
  });
  return obj;
}

function delete_getValue_(rowObj, possibleHeaders) {
  if (!rowObj) return '';

  const keys = Object.keys(rowObj);
  for (let i = 0; i < possibleHeaders.length; i++) {
    const wanted = delete_norm_(possibleHeaders[i]);
    for (let j = 0; j < keys.length; j++) {
      if (delete_norm_(keys[j]) === wanted) {
        return rowObj[keys[j]] !== undefined && rowObj[keys[j]] !== null
          ? rowObj[keys[j]]
          : '';
      }
    }
  }

  return '';
}

function delete_rowsByCaseId_(sheetName, caseId) {
  return delete_rowsByHeaderValue_(sheetName, ['Case_ID', 'Case ID'], caseId);
}

function delete_rowsByHeaderValue_(sheetName, possibleHeaders, value) {
  const info = delete_getSheetAndRows_(sheetName);
  if (info.data.length < 2) return 0;

  const idx = delete_findHeaderIndex_(info.headers, possibleHeaders);
  if (idx === -1) return 0;

  const rowsToDelete = [];
  for (let r = 1; r < info.data.length; r++) {
    if (String(info.data[r][idx] || '').trim() === String(value).trim()) {
      rowsToDelete.push(r + 1); // actual sheet row number
    }
  }

  // Delete bottom-up
  rowsToDelete.sort(function(a, b) { return b - a; });
  rowsToDelete.forEach(function(rowNum) {
    info.sheet.deleteRow(rowNum);
  });

  return rowsToDelete.length;
}


