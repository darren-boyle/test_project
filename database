function loc_buildLocationRecordFromEntry_(sheet) {
  const latitude = loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Latitude));
  const longitude = loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Longitude));
  const exactGpsChecked = loc_readCheckbox_(sheet, LOCATION_UI_MAP.Exact_GPS_Checkbox);

  const record = {
    Location_ID: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Location_ID)),
    Case_ID: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Case_ID)),
    Town_or_City: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Town_or_City)),
    County: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.County)),
    Country: loc_cleanString_(loc_readCell_(sheet, LOCATION_UI_MAP.Country)),
    Latitude: latitude,
    Longitude: longitude,
