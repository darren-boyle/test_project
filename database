 * ROW FINDERS
 *********************************/

function findEnquiryRowNumberById_(sheet, headerMap, enquiryId) {
  const idCol = headerMap['Enquiry_ID'];
  if (idCol === undefined) {
    throw new Error('Missing Enquiry_ID header');
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  // headerMap is 0-based, getRange column is 1-based
  const values = sheet.getRange(2, idCol + 1, lastRow - 1, 1).getValues();

  for (let i = 0; i < values.length; i++) {
    if (String(values[i][0] || '').trim() === enquiryId) {
      return i + 2;
    }
  }

  return null;
}

function findEnquiryRowById_(sheet, headerMap, enquiryId) {
  if (!sheet) {
    throw new Error('findEnquiryRowById_: missing sheet');
  }

  const rowNumber = findEnquiryRowNumberById_(sheet, headerMap, enquiryId);
  if (!rowNumber) return null;

  const lastCol = sheet.getLastColumn();
  if (lastCol < 1) return null;

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  const row = sheet.getRange(rowNumber, 1, 1, lastCol).getValues()[0];

  const obj = {};
  for (let c = 0; c < headers.length; c++) {
    const key = String(headers[c] || '').trim();
    if (key) obj[key] = row[c];
  }

  return obj;
}

function findLatestEnquiryRowForCase_(sheet, headerMap, caseId) {
  if (!sheet) {
    throw new Error('findLatestEnquiryRowForCase_: missing sheet');
  }

  const caseCol = headerMap['Case_ID'];
  const idCol = headerMap['Enquiry_ID'];
  const updatedCol = headerMap['Updated_At'];
  const createdCol = headerMap['Created_At'];

  if (caseCol === undefined || idCol === undefined) return null;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  const lastCol = sheet.getLastColumn();
  if (lastCol < 1) return null;

  const headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  const data = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();

  let best = null;

  for (let i = 0; i < data.length; i++) {
    const r = data[i];

    if (String(r[caseCol] || '').trim() !== caseId) continue;

    const enquiryId = String(r[idCol] || '').trim();

    const updated = updatedCol !== undefined ? r[updatedCol] : '';
    const created = createdCol !== undefined ? r[createdCol] : '';

    const score =
      (updated instanceof Date && !isNaN(updated.getTime()) ? updated.getTime() : 0) ||
      (created instanceof Date && !isNaN(created.getTime()) ? created.getTime() : 0);

    if (!best || score > best.score) {
      const obj = {};
      for (let c = 0; c < headers.length; c++) {
        const key = String(headers[c] || '').trim();
        if (key) obj[key] = r[c];
      }

      best = {
        enquiryId: enquiryId,
        score: score,
        rowObject: obj
      };
    }
  }

  return best;
}

