/**
 * Return the next global Victim_ID in VIC0001 format.
 */
function generateNextVictimId_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName('Victims');
  if (!sh) throw new Error('Missing sheet: Victims');

  const lastRow = sh.getLastRow();
  if (lastRow < 2) return 'VIC0001';

  // Column A assumed to be Victim_ID
  const values = sh.getRange(2, 1, lastRow - 1, 1).getValues().flat();

  let maxNum = 0;

  values.forEach(id => {
    const s = String(id || '').trim();
    const m = s.match(/^VIC(\d+)$/i);
    if (m) {
      const n = parseInt(m[1], 10);
      if (!isNaN(n) && n > maxNum) maxNum = n;
    }
  });

  return 'VIC' + String(maxNum + 1).padStart(4, '0');
}

/**
 * True if value is already a valid Victim_ID in VIC0001 format.
 */
function isValidVictimId_(victimId) {
  return /^VIC\d+$/i.test(String(victimId || '').trim());
}

/**
 * Normalise Victim_ID values.
 * - Keep valid VIC#### IDs
 * - Convert blank / bad / CASE####-V# style IDs into a new VIC####
 */
function normaliseVictimId_(victimId) {
  const s = String(victimId || '').trim();
  if (isValidVictimId_(s)) return s.toUpperCase();
  return generateNextVictimId_();
}

/**
 * Resolve the Victim_ID to use when saving.
 *
 * Rules:
 * - Existing victim records must already have a valid VIC#### ID
 * - New victim records get a new VIC#### if incoming ID is blank/invalid
 * - CASE####-V# must never be saved as Victim_ID
 */
function resolveVictimIdForSave_(incomingVictimId, isExistingRecord) {
  const s = String(incomingVictimId || '').trim();

  if (isExistingRecord) {
    if (!s) {
      throw new Error('Existing victim record is missing Victim_ID');
    }
    if (!isValidVictimId_(s)) {
      throw new Error('Invalid Victim_ID on existing victim record: ' + s);
    }
    return s.toUpperCase();
  }

  if (isValidVictimId_(s)) {
    return s.toUpperCase();
  }

  return generateNextVictimId_();
}

/**
 * Get victim rows for a Case_ID.
 * Returns array of objects: { rowNumber, values }
 */
function getVictimRowsByCaseId_(caseId) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName('Victims');
  if (!sh) throw new Error('Missing sheet: Victims');

  const data = sh.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0];
  const caseCol = headers.indexOf('Case_ID');
  if (caseCol === -1) throw new Error('Victims sheet missing Case_ID header');

  const target = String(caseId || '').trim();
  if (!target) return [];

  const out = [];
  for (let r = 1; r < data.length; r++) {
    const rowCaseId = String(data[r][caseCol] || '').trim();
    if (rowCaseId === target) {
      out.push({
        rowNumber: r + 1,
        values: data[r]
      });
    }
  }
  return out;
}

/**
 * Resolve which victim should be updated for the current case save.
 *
 * Behaviour:
 * - If selectedVictimId is a valid VIC#### and exists under the case, use it
 * - If case has exactly one victim row, use that row
 * - Otherwise return blank so caller knows it is a new victim or ambiguous
 */
function resolveSelectedVictimForSave_(caseId, selectedVictimId) {
  const rows = getVictimRowsByCaseId_(caseId);
  const selected = String(selectedVictimId || '').trim();

  if (selected) {
    const match = rows.find(r => String(r.values[0] || '').trim().toUpperCase() === selected.toUpperCase());
    if (match) return selected.toUpperCase();
  }

  if (rows.length === 1) {
    return String(rows[0].values[0] || '').trim().toUpperCase();
  }

  return '';
}
