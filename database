function save_appendObjectRowByHeaders_(sheet, headers, rowObj) {
  if (!sheet) throw new Error('save_appendObjectRowByHeaders_: missing sheet');
  if (!Array.isArray(headers) || !headers.length) {
    throw new Error(`save_appendObjectRowByHeaders_: missing or empty headers for sheet ${sheet.getName()}`);
