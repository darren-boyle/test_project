        setIfHeaderExists_(
          updateVictim,
          vHeaders,
          'Victim_Last_Name',
          readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Victim_Last_Name)
        );

        // Alias header variants
        const aliasValue = readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Victim_Alias);
        if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim_Alias', aliasValue)) {
          if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim Alias', aliasValue)) {
            if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim_Alias_or_Known_As', aliasValue)) {
              setIfHeaderExists_(updateVictim, vHeaders, 'Victim Alias or Known As', aliasValue);
            }
          }
        }

        const victimAgeValue = readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Victim_Age);
        if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim_Age', victimAgeValue)) {
          if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim Age', victimAgeValue)) {
            setIfHeaderExists_(updateVictim, vHeaders, 'Age', victimAgeValue);
          }
        }

        const victimSexValue = readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Victim_Sex);
        if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim_Sex', victimSexValue)) {
          if (!setIfHeaderExists_(updateVictim, vHeaders, 'Victim Sex', victimSexValue)) {
            setIfHeaderExists_(updateVictim, vHeaders, 'Sex', victimSexValue);
          }
        }

       // IMPORTANT: save F39 factual summary / case outline back to victim notes
        const factualSummaryValue = readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Factual_Summary);
        setVictimFactualSummary_(updateVictim, vHeaders, factualSummaryValue);

        auditChanges_(
          'Victims',
          vHeaders,
          existingVictimRow,
          updateVictim,
          selectedVictimId
        );
        Logger.log(
          'Victim update for ' + selectedVictimId +
