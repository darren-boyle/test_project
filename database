 * EVENT PAYLOAD BUILDERS
 *********************************/

function readEntryEventForm_(entry, caseId) {
  const payload = {
    Case_ID: caseId
  };

  const currentEventId = getCurrentEventId_(entry);
  if (currentEventId) {
    payload.Event_ID = currentEventId;
  }

  const eventDate = readEntryDisplay_(entry, EVENT_ENTRY_MAP.Event_Date);
  const eventType = readEntryDisplay_(entry, EVENT_ENTRY_MAP.Event_Type);
  const eventDescription = readMergedOrSingleValue_(entry, EVENT_ENTRY_MAP.Event_Description);

  const info = save_getSheetAndHeaders_('Case_Events');
  const headers = info.headers;

  setIfHeaderExists_(payload, headers, 'Case_ID', caseId);
  setIfHeaderExists_(payload, headers, 'Event_ID', payload.Event_ID || '');

  if (!setIfHeaderExists_(payload, headers, 'Event_Date', eventDate)) {
    setIfHeaderExists_(payload, headers, 'Date', eventDate);
  }

  if (!setIfHeaderExists_(payload, headers, 'Event_Type', eventType)) {
    setIfHeaderExists_(payload, headers, 'Type', eventType);
  }

  if (!setIfHeaderExists_(payload, headers, 'Event_Description', eventDescription)) {
    if (!setIfHeaderExists_(payload, headers, 'Event_Summary', eventDescription)) {
      if (!setIfHeaderExists_(payload, headers, 'Summary', eventDescription)) {
        setIfHeaderExists_(payload, headers, 'Details', eventDescription);
      }
    }
  }

  return payload;
}


function hasAnyCaseEventInput_(eventPayload) {
  const ignore = { Event_ID: true, Case_ID: true };

  return Object.keys(eventPayload || {}).some(function(k) {
    if (ignore[k]) return false;
    const v = eventPayload[k];
    return String(v || '').trim() !== '';
  });
}

function readMergedOrSingleValue_(sheet, a1) {
  if (!sheet || !a1) return '';

  try {
    return String(sheet.getRange(a1).getDisplayValue() || '').trim();
  } catch (err) {
    Logger.log('readMergedOrSingleValue_ failed for ' + a1 + ': ' + err);
    return '';
  }
}
