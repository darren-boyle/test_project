/** ============================================================================
 * Town / county / country lookup helpers
 * Safe version: if Town_Country_Map is missing or empty, returns blank
 * instead of crashing the load flow.
 * ========================================================================== */

const LOC_TOWN_MAP_SHEET_NAME = 'Town_Country_Map';
const LOC_TOWN_MAP_HEADER_ROW = 1;

function getCountyFromTown_(townOrCity) {
  return loc_getTownMapValue_(townOrCity, 'County');
}

function getCountryFromTown_(townOrCity) {
  return loc_getTownMapValue_(townOrCity, 'Country');
}

function getLondonBoroughFromTown_(townOrCity) {
  return loc_getTownMapValue_(townOrCity, 'London_Borough');
}

/**
 * Generic lookup against Town_Country_Map.
 * Expected headers:
 *   Town_or_City
 *   County
 *   Country
 *   London_Borough
 *
 * Safe behaviour:
 * - blank input => ''
 * - missing sheet => ''
 * - missing headers => ''
 * - no matching town => ''
 */
function loc_getTownMapValue_(townOrCity, targetHeader) {
  const town = String(townOrCity || '').trim();
  if (!town) return '';

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(LOC_TOWN_MAP_SHEET_NAME);
  if (!sh) return '';

  const lastRow = sh.getLastRow();
  const lastCol = sh.getLastColumn();
  if (lastRow < 2 || lastCol < 1) return '';

  const headers = sh.getRange(LOC_TOWN_MAP_HEADER_ROW, 1, 1, lastCol).getValues()[0];
  const data = sh.getRange(
    LOC_TOWN_MAP_HEADER_ROW + 1,
    1,
    lastRow - LOC_TOWN_MAP_HEADER_ROW,
    lastCol
  ).getValues();

  const headerMap = {};
  headers.forEach(function(header, index) {
    const key = String(header || '').trim();
    if (key) headerMap[key] = index;
  });

  const townIdx = headerMap['Town_or_City'];
  const targetIdx = headerMap[targetHeader];

  if (townIdx === undefined || targetIdx === undefined) return '';

  const townLower = town.toLowerCase();

  for (let i = 0; i < data.length; i++) {
    const rowTown = String(data[i][townIdx] || '').trim().toLowerCase();
    if (rowTown && rowTown === townLower) {
      return String(data[i][targetIdx] || '').trim();
    }
  }

  return '';
}

function backfillLocationFieldsFromTown_(locationRecord) {
  if (!locationRecord) return locationRecord;

  const town = String(locationRecord.Town_or_City || '').trim();
  if (!town) return locationRecord;

  if (!String(locationRecord.County || '').trim()) {
    locationRecord.County = getCountyFromTown_(town);
  }

  if (!String(locationRecord.Country || '').trim()) {
    locationRecord.Country = getCountryFromTown_(town);
  }

  if (!String(locationRecord.London_Borough || '').trim()) {
    locationRecord.London_Borough = getLondonBoroughFromTown_(town);
  }

  return locationRecord;
}

function safeBackfillLocationFieldsFromTown_(locationRecord) {
  try {
    return backfillLocationFieldsFromTown_(locationRecord);
  } catch (err) {
    Logger.log('safeBackfillLocationFieldsFromTown_: lookup skipped: ' + err);
    return locationRecord;
  }
}

