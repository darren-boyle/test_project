  if (!sheet) throw new Error(`Missing sheet: ${sheetName}`);

  const lastCol = safeGetLastColumn_(sheet, `sheet in save_getSheetAndHeaders_ for ${sheetName}`);
  if (lastCol < 1) throw new Error(`Sheet has no headers: ${sheetName}`);

