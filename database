function saveOrUpdateLiveEnquiry() {
  const entry = getUserEntrySheet_();
  if (!entry) throw new Error('Missing entry sheet for current user');

  const caseId = getCurrentCaseId_(null, entry);
  if (!caseId) {
    SpreadsheetApp.getActive().toast(
      'No Current_Case_ID set (G11 is blank). Search and load a case first.',
      'Live Enquiry',
      4
    );
    return;
  }

  const form = readLiveEnquiryFromForm_();
  const shouldSave = !!(
    form.enquiryType ||
    form.targetValue ||
    form.outcomeStatus ||
    form.targetAddress
  );

  if (!shouldSave) {
    SpreadsheetApp.getActive().toast(
      'Live enquiry block is blank — nothing to save.',
      'Live Enquiry',
      4
    );
    return;
  }

  const live = save_getSheetAndHeaders_('Case_Live_Enquiries');
  const currentEnquiryId = String(
    entry.getRange(LIVE_ENQUIRY_UI.CURRENT_ENQUIRY_ID_CELL).getDisplayValue() || ''
  ).trim();

  const existingRowNumber = currentEnquiryId
    ? findEnquiryRowNumberById_(live.sheet, live.map, currentEnquiryId)
    : null;

  // UPDATE
  if (existingRowNumber) {
    const updateObj = {};

    setIfHeaderExists_(updateObj, live.headers, 'Enquiry_ID', currentEnquiryId);
    setIfHeaderExists_(updateObj, live.headers, 'Case_ID', caseId);

    setIfHeaderExists_(updateObj, live.headers, 'Enquiry_Date', form.enquiryDate);
    setIfHeaderExists_(updateObj, live.headers, 'Enquiry_Type', form.enquiryType);
    setIfHeaderExists_(updateObj, live.headers, 'Target_Type', form.targetType);
    setIfHeaderExists_(updateObj, live.headers, 'Target_Value', form.targetValue);
    setIfHeaderExists_(updateObj, live.headers, 'Target_Address', form.targetAddress);
    setIfHeaderExists_(updateObj, live.headers, 'Platform', form.platform);
    setIfHeaderExists_(updateObj, live.headers, 'Outcome_Status', form.outcomeStatus);
    setIfHeaderExists_(updateObj, live.headers, 'Attempted_By', form.attemptedBy);
    setIfHeaderExists_(updateObj, live.headers, 'Outcome_Notes', form.outcomeNotes);
    setIfHeaderExists_(updateObj, live.headers, 'Public_Source_Only', save_normaliseCheckbox_(form.publicSourceOnly));
    setIfHeaderExists_(updateObj, live.headers, 'Do_Not_Recontact', save_normaliseCheckbox_(form.doNotRecontact));
    setIfHeaderExists_(updateObj, live.headers, 'Last_Reviewed', form.enquiryDate || new Date());
    setIfHeaderExists_(updateObj, live.headers, 'Updated_At', new Date());

    const existingRow = live.sheet
      .getRange(existingRowNumber, 1, 1, live.headers.length)
      .getValues()[0];

    auditChanges_(
      'Case_Live_Enquiries',
      live.headers,
      existingRow,
      updateObj,
      currentEnquiryId
    );

    writeObjectToRowByHeaders_(live.sheet, existingRowNumber, live.headers, updateObj);

    SpreadsheetApp.getActive().toast(
      'Updated enquiry ' + currentEnquiryId,
      'Live Enquiry',
      4
    );
    return currentEnquiryId;
  }

  // INSERT NEW
  const enquiryId = save_nextIdByPrefix_(live.sheet, live.map, 'Enquiry_ID', 'ENQ-');

  const rowObj = save_blankRowObject_(live.headers);
  setIfHeaderExists_(rowObj, live.headers, 'Enquiry_ID', enquiryId);
  setIfHeaderExists_(rowObj, live.headers, 'Case_ID', caseId);

  setIfHeaderExists_(rowObj, live.headers, 'Enquiry_Date', form.enquiryDate);
  setIfHeaderExists_(rowObj, live.headers, 'Enquiry_Type', form.enquiryType);
  setIfHeaderExists_(rowObj, live.headers, 'Target_Type', form.targetType);
  setIfHeaderExists_(rowObj, live.headers, 'Target_Value', form.targetValue);
  setIfHeaderExists_(rowObj, live.headers, 'Target_Address', form.targetAddress);
  setIfHeaderExists_(rowObj, live.headers, 'Platform', form.platform);
  setIfHeaderExists_(rowObj, live.headers, 'Outcome_Status', form.outcomeStatus);
  setIfHeaderExists_(rowObj, live.headers, 'Attempted_By', form.attemptedBy);
  setIfHeaderExists_(rowObj, live.headers, 'Outcome_Notes', form.outcomeNotes);
  setIfHeaderExists_(rowObj, live.headers, 'Public_Source_Only', save_normaliseCheckbox_(form.publicSourceOnly));
  setIfHeaderExists_(rowObj, live.headers, 'Do_Not_Recontact', save_normaliseCheckbox_(form.doNotRecontact));
  setIfHeaderExists_(rowObj, live.headers, 'Last_Reviewed', form.enquiryDate || new Date());
  setIfHeaderExists_(rowObj, live.headers, 'Created_At', new Date());
  setIfHeaderExists_(rowObj, live.headers, 'Updated_At', new Date());

  save_appendObjectRowByHeaders_(live.sheet, live.headers, rowObj);

  entry.getRange(LIVE_ENQUIRY_UI.CURRENT_ENQUIRY_ID_CELL).setValue(enquiryId);

  SpreadsheetApp.getActive().toast(
    'Saved new enquiry ' + enquiryId,
    'Live Enquiry',
    4
  );

  return enquiryId;
}
