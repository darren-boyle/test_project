    'loadSelectedCaseIntoEntry_',
    'loadExistingCase_',
    'loadCase_',
    'populateEntryFromCase_',
    'populateEntryFormFromCase_',
    'loadExistingCaseIntoEntry_',
    'loadCaseRecord_',
    'entry_loadCase_',
    'case_loadIntoEntry_'
  ];

  const root = (typeof globalThis !== 'undefined') ? globalThis : this;
  const found = [];
  const errors = [];

  for (var i = 0; i < candidates.length; i++) {
    var fnName = candidates[i];
    var fn = root[fnName];

    if (typeof fn !== 'function') continue;

    found.push(fnName);

