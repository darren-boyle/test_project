function rebuildNewCaseEntryValidations_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = getUserEntrySheet_();
  const lists = ss.getSheetByName('Controlled_Lists');

  if (!sheet || !lists) throw new Error('Missing required sheets');

  // Use RangeList to clear multiple separate validation targets instantly
  sheet.getRangeList(['G5', 'G11', 'I11', 'B24', 'B64', 'B65', 'B68', 'B69', 'B75', 'B76', 'B77'])
       .clearDataValidations();

  const dropdownMap = getDropdownMap_();
  const rules = Object.keys(dropdownMap).map(key => ({
    cell: dropdownMap[key].cell,
    range: dropdownMap[key].rangeA1.replace('Controlled_Lists!', '')
  }));

  // Append standalone dropdowns
  rules.push(
    { cell: 'B62', range: 'S2:S' },
    { cell: 'B63', range: 'V2:V' },
    { cell: 'B66', range: 'U2:U' },
    { cell: 'B67', range: 'T2:T' },
    { cell: 'B79', range: 'W2:W' }
  );

  // Group validations processing
  rules.forEach(r => {
    try {
      const rule = SpreadsheetApp.newDataValidation()
        .requireValueInRange(lists.getRange(r.range), true)
        .setAllowInvalid(false)
        .build();
      sheet.getRange(r.cell).setDataValidation(rule);
    } catch (e) {
      Logger.log(`Validation failed for ${r.cell}: ${e.message}`);
    }
  });

  SpreadsheetApp.getActive().toast('Validations rebuilt', 'UK Murder DB', 4);
}

