function saveOrUpdateCaseEvent() {
  const entry = getUserEntrySheet_();
  if (!entry) throw new Error('Missing entry sheet for current user');

  const caseId = String(
    entry.getRange(EVENT_ENTRY_MAP.currentCaseId).getDisplayValue() || ''
  ).trim();

  if (!caseId) {
    setSearchStatusSafe_(entry, 'Event save failed: no loaded Case_ID');
    return '';
  }

  const eventPayload = readEntryEventForm_(entry, caseId);

  if (!hasAnyCaseEventInput_(eventPayload)) {
    setSearchStatusSafe_(entry, 'No event data to save');
    return '';
  }

  try {
    setSearchStatusSafe_(entry, 'Saving event...');

    const result = saveCaseEvent_(eventPayload);

    // Keep helper state in sync
    if (result && result.eventId) {
      setCurrentEventId_(entry, result.eventId);
    }

    if (result && result.action === 'updated') {
      setSearchStatusSafe_(entry, 'Event updated ✅ ' + result.eventId);
      return result.eventId;
    }

    if (result && result.action === 'created') {
      setSearchStatusSafe_(entry, 'Event saved ✅ ' + result.eventId);
      return result.eventId;
    }

    setSearchStatusSafe_(entry, 'Event save completed');
    return '';

  } catch (err) {
    setSearchStatusSafe_(entry, 'Event save failed: ' + err.message);
    throw err;
  }
}
/*********************************
 * CORE TABLE WRITER
 *********************************/

function saveCaseEvent_(eventPayload) {
  const ss = SpreadsheetApp.getActive();
  const sh = ss.getSheetByName('Case_Events');
  if (!sh) throw new Error('Sheet not found: Case_Events');

  const headers = sh.getRange(1, 1, 1, sh.getLastColumn()).getValues()[0];
  const headerMap = getHeaderMap_(headers);

  if (headerMap['Event_ID'] === undefined) {
    throw new Error('Case_Events is missing header: Event_ID');
  }
  if (headerMap['Case_ID'] === undefined) {
    throw new Error('Case_Events is missing header: Case_ID');
  }

  if (!eventPayload || !eventPayload.Case_ID) {
    throw new Error('saveCaseEvent_: missing required Case_ID');
  }

  const incomingEventId = String(eventPayload.Event_ID || '').trim();

  // ---------------------------------
  // Update existing event ONLY by Event_ID
  // ---------------------------------
  if (incomingEventId) {
    const existingRow = findRowByExactId_(
      sh,
      headerMap['Event_ID'] + 1, // convert 0-based to 1-based
      incomingEventId
    );

    if (!existingRow) {
      throw new Error('Event_ID not found in Case_Events: ' + incomingEventId);
    }

    const oldRow = sh
      .getRange(existingRow, 1, 1, sh.getLastColumn())
      .getValues()[0];

    eventPayload.Event_ID = incomingEventId;

    auditChanges_('Case_Events', headers, oldRow, eventPayload, incomingEventId);
    writeObjectToRowByHeaders_(sh, existingRow, headers, eventPayload);

    logAuditIfAvailable_({
      actionType: 'UPDATE_EVENT',
      recordId: incomingEventId,
      notes: 'Case event updated',
      sourceForm: getUserEntrySheet_().getName()
    });

    return {
      action: 'updated',
      eventId: incomingEventId
    };
  }

  // ---------------------------------
  // Create new event
  // ---------------------------------
  const nextId = nextSequentialId_(
    sh,
    headerMap['Event_ID'] + 1, // convert 0-based to 1-based
    'EVT',
    4
  );

  eventPayload.Event_ID = nextId;

  appendObjectByHeaders_(sh, headers, eventPayload);

  logAuditIfAvailable_({
    actionType: 'CREATE_EVENT',
    recordId: nextId,
    notes: 'Case event created',
    sourceForm: getUserEntrySheet_().getName()
  });

  return {
    action: 'created',
    eventId: nextId
  };
}
