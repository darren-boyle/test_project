  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Location_ID, record.Location_ID);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Case_ID, record.Case_ID);
