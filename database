/**
 * Generate the next Case_Location_Ref for a given case.
 * Produces L1, L2, L3... within that Case_ID.
 *
 * Example:
 * - first location for CASE0007  -> L1
 * - second location for CASE0007 -> L2
 */
function getNextCaseLocationRef_(caseId) {
  const caseIdClean = String(caseId || '').trim();
  if (!caseIdClean) {
    throw new Error('getNextCaseLocationRef_: missing caseId');
  }

  const info = save_getSheetAndHeaders_('Locations');
  const sheet = info.sheet;
  const map = info.map;

  const caseIdCol = map['Case_ID'];
  const refCol =
    map['Case_Location_Ref'] !== undefined
      ? map['Case_Location_Ref']
      : map['Case Location Ref'];

  if (caseIdCol === undefined) {
    throw new Error('Locations sheet missing Case_ID header');
  }

  // If the ref column does not exist, default safely to L1.
  // setIfHeaderExists_ will simply skip writing it later if the header is absent.
  if (refCol === undefined) {
    return 'L1';
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) {
    return 'L1';
  }

  const values = sheet.getRange(2, 1, lastRow - 1, Math.max(caseIdCol, refCol) + 1).getValues();

  let maxRef = 0;
  let matchingCount = 0;

  values.forEach(function(row) {
    const rowCaseId = String(row[caseIdCol] || '').trim();
    if (rowCaseId !== caseIdClean) return;

    matchingCount++;

    const refValue = String(row[refCol] || '').trim();
    const m = refValue.match(/^L(\d+)$/i);
    if (m) {
      const n = parseInt(m[1], 10);
      if (!isNaN(n) && n > maxRef) {
        maxRef = n;
      }
    }
  });

  // If rows exist for this case but refs were blank/non-standard,
  // still move forward safely based on count.
  if (maxRef === 0 && matchingCount > 0) {
    return 'L' + String(matchingCount + 1);
  }

  return 'L' + String(maxRef + 1);
}
