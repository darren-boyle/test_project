  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.County, record.County);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Country, record.Country);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Latitude, record.Latitude);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Longitude, record.Longitude);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Location_Precision, record.Location_Precision);
  loc_writeRecordValue_(sheet, targetRow, headerMap, LOCATION_SHEET_COLUMNS.Exact_Address, record.Exact_Address);
