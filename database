/**
 * Get sheet + headers + 0-based header map + data rows.
 */
function load_getSheetAndHeaders_(sheetName) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(sheetName);

  if (!sh) {
    throw new Error('Missing sheet: ' + sheetName);
  }

  var lastRow = sh.getLastRow();
  var lastCol = sh.getLastColumn();

  if (lastCol < 1) {
    throw new Error('Sheet has no columns: ' + sheetName);
  }

  var headers = sh.getRange(1, 1, 1, lastCol).getDisplayValues()[0];
  var map = {};

  headers.forEach(function(h, i) {
    var key = String(h || '')
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '_')
      .replace(/^_+|_+$/g, '');

    if (key) {
      map[key] = i;
    }
  });

  var values = [];
  if (lastRow >= 2) {
    values = sh.getRange(2, 1, lastRow - 1, lastCol).getValues();
  }

  return {
    sheet: sh,
    headers: headers,
    map: map,
    values: values
  };
}

/**
 * Read a row value using one or more header aliases.
 */
function load_readField_(row, map, aliases) {
  aliases = aliases || [];

  for (var i = 0; i < aliases.length; i++) {
    var key = String(aliases[i] || '')
      .trim()
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '_')
      .replace(/^_+|_+$/g, '');

    if (map.hasOwnProperty(key)) {
      var value = row[map[key]];
      if (value !== null && value !== undefined && String(value).trim() !== '') {
        return value;
      }
