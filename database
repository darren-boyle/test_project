/**
 * Generates the next sequential ID based on a prefix.
 * headerMap is expected to be 0-based.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {Object} headerMap
 * @param {string} idHeader
 * @param {string} prefix
 * @return {string}
 */
function save_nextIdByPrefix_(sheet, headerMap, idHeader, prefix) {
  const idCol = headerMap[idHeader];
  if (idCol === undefined) {
    throw new Error(`Missing ID header "${idHeader}" on sheet: ${sheet.getName()}`);
  }

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return `${prefix}0001`;

  const values = sheet
    .getRange(2, idCol + 1, lastRow - 1, 1)
    .getValues()
    .flat();

  let maxNum = 0;
  const regex = new RegExp(`^${escapeRegex_(prefix)}(\\d+)$`);

  values.forEach(v => {
    const m = String(v || '').trim().match(regex);
    if (m) {
      const n = parseInt(m[1], 10);
      if (!isNaN(n) && n > maxNum) maxNum = n;
    }
  });

  return prefix + String(maxNum + 1).padStart(4, '0');
}

/**
 * Flexible header map helper. Accepts either a Sheet object or a 1D header row array.
 * Returns: { headerName: zeroBasedIndex, ... }
 * @param {GoogleAppsScript.Spreadsheet.Sheet|Array<string>} sheetOrHeaders
 * @return {Object}
 */
function getHeaderMap_(sheetOrHeaders) {
  let headers = [];

  if (sheetOrHeaders && typeof sheetOrHeaders.getRange === 'function' && typeof sheetOrHeaders.getLastColumn === 'function') {
    const lastCol = safeGetLastColumn_(sheetOrHeaders, 'sheetOrHeaders in getHeaderMap_');
    if (lastCol < 1) return {};
    headers = sheetOrHeaders.getRange(1, 1, 1, lastCol).getDisplayValues()[0];
  } else if (Array.isArray(sheetOrHeaders)) {
    headers = sheetOrHeaders;
  } else {
    return {};
  }

  const map = {};
  headers.forEach((header, i) => {
    const raw = String(header || '').trim();
    if (!raw) return;

    map[raw] = i;
    map[raw.replace(/\s+/g, '_')] = i;
    map[raw.replace(/_/g, ' ')] = i;
  });

  return map;
}

/**
 * Safe header-aware setter for row objects.
 * Supports either a headers array or a header map.
 * @param {Object} rowObj
 * @param {Array<string>|Object} headersOrMap
 * @param {string} headerName
 * @param {any} value
 * @return {boolean}
 */
function setIfHeaderExists_(rowObj, headersOrMap, headerName, value) {
  if (!rowObj || !headersOrMap || !headerName) return false;
  const target = String(headerName).trim();

  if (Array.isArray(headersOrMap)) {
    const found = headersOrMap.some(h => String(h || '').trim() === target);
    if (found) {
      rowObj[target] = value;
      return true;
    }
    return false;
  }

  if (typeof headersOrMap === 'object') {
    if (headersOrMap[target] !== undefined) {
      rowObj[target] = value;
      return true;
    }
    const alt1 = target.replace(/\s+/g, '_');
    const alt2 = target.replace(/_/g, ' ');

    if (headersOrMap[alt1] !== undefined) {
      rowObj[alt1] = value;
      return true;
    }
    if (headersOrMap[alt2] !== undefined) {
      rowObj[alt2] = value;
      return true;
    }
  }
  return false;
}

/**
 * Safely clear one or more ranges on a sheet. Clear contents only by default.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {string|Array<string>|GoogleAppsScript.Spreadsheet.Range|Array<GoogleAppsScript.Spreadsheet.Range>} ranges
 * @param {Object} [options]
 */
function clearRangesSafe_(sheet, ranges, options) {
  if (!sheet) throw new Error('clearRangesSafe_: missing sheet');

  const opts = options || {};
  const clearContentsOnly = opts.contentsOnly !== false;
  const clearValidations = opts.validations === true;
  const clearNotes = opts.notes === true;
  const clearFormats = opts.formats === true;

  const list = normaliseRangesForClear_(sheet, ranges);
  if (!list.length) return;

  list.forEach(rng => {
    if (!rng) return;
    try {
      if (clearContentsOnly) {
        rng.clearContent();
      } else {
        rng.clear();
      }
      if (clearValidations) rng.clearDataValidations();
      if (clearNotes) rng.clearNote();
      if (clearFormats) rng.clearFormat();
    } catch (err) {
      throw new Error(`clearRangesSafe_ failed on ${rng.getA1Notation()}: ${err.message}`);
    }
  });
}

/**
 * Normalises incoming range input into live Range objects.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {any} ranges
 * @return {Array<GoogleAppsScript.Spreadsheet.Range>}
 */
function normaliseRangesForClear_(sheet, ranges) {
  if (!ranges) return [];
  const input = Array.isArray(ranges) ? ranges : [ranges];
  const out = [];

  input.forEach(item => {
    if (!item) return;
    if (typeof item.getA1Notation === 'function') {
      out.push(item);
    } else if (typeof item === 'string') {
      out.push(sheet.getRange(item));
    }
  });
  return out;
}

