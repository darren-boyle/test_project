    }
  } catch (e7) {}

  return true;
}

/**
 * Main search runner using the real merged search term box (G5:H5).
 */
function runSearchCases(sheet) {
  var sh = sheet || search_getEntrySheetSafe_();
  if (!sh) throw new Error('runSearchCases: missing entry sheet');

  var text = search_getSearchQuery_(sh);

  if (!text) {
    search_clearSearchOutputs_(sh);
    return 0;
  }

  if (text.length < 3) {
    try { search_setSearchStatusSafe_(sh, 'Enter at least 3 characters'); } catch (e1) {}
    try {
      if (typeof SEARCH_UI !== 'undefined' && SEARCH_UI && SEARCH_UI.SearchMessage) {
        sh.getRange(SEARCH_UI.SearchMessage).setValue('Enter at least 3 characters');
      }
    } catch (e2) {}
    return 0;
  }

  var results = search_findMatches_(text, 100);

  // Clear stale display before repainting
  search_clearSearchOutputs_(sh);

  // Rebuild dropdown
  search_writeVictimPicker_(sh, results);

  // Optional status / message
  try {
    search_setSearchStatusSafe_(sh, results.length ? (results.length + ' result(s)') : 'No matches found');
  } catch (e3) {}

  try {
    if (typeof SEARCH_UI !== 'undefined' && SEARCH_UI && SEARCH_UI.SearchMessage) {
      sh.getRange(SEARCH_UI.SearchMessage).setValue(
        results.length ? (results.length + ' result(s)') : 'No matches found'
      );
    }
  } catch (e4) {}

  // If one exact/only result, preview it immediately
  if (results.length === 1) {
    var row = search_normaliseIndexRow_(results[0]);
    try { search_setCurrentCaseId_(row.caseId || '', sh); } catch (e5) {}
    try { search_writeSelectedCaseId_(sh, row.caseId || ''); } catch (e6) {}
    try { search_writePreviewRow_(sh, row); } catch (e7) {}
  }

  return results.length;
}


/**
 * Search-specific onEdit bridge.
 * - typing in the search box reruns search
 * - choosing from the picker writes the selected Case_ID + preview
 */
function search_onEdit_(e) {
  try {
    if (!e || !e.range) return;

    var sh = e.range.getSheet();
    var entry = search_getEntrySheetSafe_();
    if (!entry) return;
    if (sh.getSheetId() !== entry.getSheetId()) return;

    var editedA1 = e.range.getA1Notation();
    var searchBoxA1 = search_getSearchBoxCellA1_();
    var pickerA1 = search_getVictimPickerCellA1_();

    // Typing in the live search box
    if (editedA1 === searchBoxA1 || editedA1 === 'H6' || editedA1 === 'I6' || editedA1 === 'B6') {
      runSearchCases();
      return;
    }

    // Choosing a result from the dropdown
    if (editedA1 === pickerA1) {
      handleSearchResultSelection_(e);
      return;
    }
  } catch (err) {
    Logger.log('search_onEdit_ error: ' + err);
  }
}
