/**
 * Export full JSON payload from the export sheet into a helper sheet.
 * Useful for copy/paste into web workflows.
 */
function exportColdCaseDeepDiveAsJson_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Cold_Case_Deep_Dive_Export');

  if (!sheet) {
    throw new Error('Missing sheet: Cold_Case_Deep_Dive_Export');
  }

  const data = sheet.getDataRange().getValues();

  if (data.length < 2) {
    throw new Error('Export sheet is empty');
  }

  const headers = data[0];
  const rows = data.slice(1);

  const records = rows.map(function(row) {
    const obj = {};

    headers.forEach(function(header, i) {
      obj[header] = row[i];
    });

    if (obj.Record_JSON) {
      try {
        return JSON.parse(obj.Record_JSON);
      } catch (e) {
        return obj;
      }
    }

    return obj;
  });

  const jsonString = JSON.stringify(records, null, 2);

  const outputSheetName = 'Cold_Case_JSON';
  let outputSheet = ss.getSheetByName(outputSheetName);

  if (!outputSheet) {
    outputSheet = ss.insertSheet(outputSheetName);
  } else {
    outputSheet.clear();
  }

  outputSheet.getRange('A1').setValue(jsonString);

  SpreadsheetApp.flush();
  Logger.log(jsonString);

  SpreadsheetApp.getActive().toast(
    'Cold_Case_JSON created from Record_JSON',
    'Deep Dive JSON',
    5
  );

  return outputSheetName;
}

