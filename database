/**
 * Force-read critical fields from known cells / labels.
 * Fallback to programmatic column scanning if default references fail.
 */
function save_forceCriticalFields_(sheet, flat) {
  if (!sheet || !flat) return;

  // Cache column A display values to prevent multiple trips to the server
  const lastRow = sheet.getLastRow();
  const labels = lastRow > 0 ? sheet.getRange(1, 1, lastRow, 1).getDisplayValues() : [];

  const directTown = save_readCellTrim_(sheet, 'B24');
  const directSourceType = save_readCellTrim_(sheet, 'B42');

  const townByLabel = save_findValueByLabelCached_(sheet, labels, /^Town\s*\/\s*City$/i);
  const sourceByLabel = save_findValueByLabelCached_(sheet, labels, /^Source\s*type$/i);

  flat.townOrCity = townByLabel.found ? townByLabel.value : directTown;
  flat.sourceType = sourceByLabel.found ? sourceByLabel.value : directSourceType;
}

/**
 * Read a trimmed display value from a specific cell coordinate.
 */
function save_readCellTrim_(sheet, a1) {
  if (!sheet || !a1) return '';
  try {
    return String(sheet.getRange(a1).getDisplayValue() || '').trim();
  } catch (err) {
    Logger.log(`save_readCellTrim_ failed for ${a1}: ${err.message}`);
    return '';
  }
}

/**
 * Scan an already cached block of Column A rows for matching string signatures.
 * This completely avoids fetching the grid from the server over and over again.
 */
function save_findValueByLabelCached_(sheet, labelMatrix, labelRegex) {
  if (!sheet || !labelRegex || !labelMatrix.length) {
    return { found: false, row: null, value: '' };
  }

  for (let i = 0; i < labelMatrix.length; i++) {
    const label = String(labelMatrix[i][0] || '').trim();

    if (label && labelRegex.test(label)) {
      const row = i + 1;
      return { 
        found: true, 
        row: row, 
        value: save_readCellTrim_(sheet, `B${row}`) 
      };
    }
  }
  return { found: false, row: null, value: '' };
}

/**
 * Legacy compatibility fallback to fetch array map directly if not passed down.
 */
function save_findValueByLabel_(sheet, labelRegex) {
  if (!sheet || !labelRegex) return { found: false, row: null, value: '' };
  const lastRow = sheet.getLastRow();
  const labels = lastRow > 0 ? sheet.getRange(1, 1, lastRow, 1).getDisplayValues() : [];
  return save_findValueByLabelCached_(sheet, labels, labelRegex);
}

/**
 * Utility helper to handle polymorphic function inputs:
 * Accepts (sheet, "A1") OR ("A1") defaulting to current user sheet.
 * @private
 */
function resolveSheetAndRange_(sheetOrA1, maybeA1) {
  if (typeof sheetOrA1 === 'string') {
    return { 
      sheet: typeof getUserEntrySheet_ === 'function' ? getUserEntrySheet_() : null, 
      a1: sheetOrA1 
    };
  }
  return { 
    sheet: sheetOrA1 || (typeof getUserEntrySheet_ === 'function' ? getUserEntrySheet_() : null), 
    a1: maybeA1 
  };
}

/**
 * Safe trimmed display-value reader from the entry sheet.
 */
function readEntryDisplay_(sheetOrA1, maybeA1) {
  const { sheet, a1 } = resolveSheetAndRange_(sheetOrA1, maybeA1);
  if (!sheet || !a1) return '';

  try {
    return String(sheet.getRange(a1).getDisplayValue() || '').trim();
  } catch (err) {
    Logger.log(`readEntryDisplay_ failed for ${a1}: ${err.message}`);
    return '';
  }
}

/**
 * Safe raw-value reader from the entry sheet (.getValue()).
 */
function readEntryValue_(sheetOrA1, maybeA1) {
  const { sheet, a1 } = resolveSheetAndRange_(sheetOrA1, maybeA1);
  if (!sheet || !a1) return '';

  try {
    return sheet.getRange(a1).getValue();
  } catch (err) {
    Logger.log(`readEntryValue_ failed for ${a1}: ${err.message}`);
    return '';
  }
}

/**
 * Read a checkbox-style field from the entry sheet and normalise it to true/false.
 */
function readEntryCheckbox_(sheetOrA1, maybeA1) {
  const raw = readEntryValue_(sheetOrA1, maybeA1);
  
  if (typeof raw === 'boolean') return raw;
  if (raw === null || raw === undefined) return false;

  const normalizedStr = String(raw).trim().toLowerCase();
  return ['true', 'yes', 'y', '1'].includes(normalizedStr);
}

/**
 * Backwards-compatible alias used elsewhere in the project.
 */
function readCheckbox_(sheetOrA1, maybeA1) {
  return readEntryCheckbox_(sheetOrA1, maybeA1);
}
