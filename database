/**
 * Populate the victim picker in I11 using display labels.
 *
 * If only one victim exists, auto-select it.
 */
function populateVictimPicker_(entry, victims) {
  const sh = entry || getUserEntrySheet_();
  if (!sh) return;

  const cell = sh.getRange(VICTIM_PICKER_CELL);

  cell.clearContent();
  cell.clearDataValidations();

  if (!victims || !victims.length) return;

  const labels = victims
    .map(function(v) {
      return buildVictimDisplayLabel_(v);
    })
    .filter(function(label) {
      return !!String(label || '').trim();
    });

  if (!labels.length) return;

  const rule = SpreadsheetApp.newDataValidation()
    .requireValueInList(labels, true)
    .setAllowInvalid(false)
    .setHelpText('Choose the correct victim')
    .build();

  cell.setDataValidation(rule);

  if (labels.length === 1) {
    cell.setValue(labels[0]);
  }
}
