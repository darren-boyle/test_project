/**
 * Single top-level selection-change trigger.
 *
 * Current responsibilities:
 * - preview row click (H9:N9) => apply case/victim selection logic
 * - image click block (column B, rows 82:86) => open linked image
 */
function onSelectionChange(e) {
  // Defensive early exit if event object properties are missing
  if (!e || !e.range) return;

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) return;

  try {
    const range = e.range;
    const sheet = range.getSheet();
    if (!sheet) return;

    const sheetName = String(sheet.getName() || '').trim();
    
    // Guard against helper function non-existence or mismatch
    if (typeof getAllEntrySheetNames_ !== 'function') {
      throw new Error("Core routing function 'getAllEntrySheetNames_' is missing or broken in other script files.");
    }
    if (getAllEntrySheetNames_().indexOf(sheetName) === -1) return;

    const row = range.getRow();
    const col = range.getColumn();

    // 1. Preview row click handler: H9:N9 (Column 8 to 14)
    if (row === 9 && col >= 8 && col <= 14) {
      if (typeof handlePreviewRowClick_ === 'function') {
        handlePreviewRowClick_(sheet);
      } else {
        throw new Error("'handlePreviewRowClick_' worker function could not be found.");
      }
      return;
    }

    // 2. Image click handler: column B, rows 82:86
    if (col === 2 && row >= 82 && row <= 86) {
      const formula = range.getFormula();
      if (!formula) return;

      const match = formula.match(/"(https?:\/\/[^"]+)"/);
      if (!match || !match[1]) return;

      const url = match[1];

      // Injection sanitized execution payload
      const htmlContent = `
        <div style="font-family: Arial, sans-serif; padding: 10px; text-align: center;">
          <p>Redirecting to case attachment...</p>
          <script>
            window.open("${encodeURI(url)}", "_blank");
            google.script.host.close();
          </script>
        </div>
      `;

      const html = HtmlService.createHtmlOutput(htmlContent)
        .setWidth(300)
        .setHeight(100);

      SpreadsheetApp.getUi().showModalDialog(html, 'Opening Case Evidence Profile...');
    }

  } catch (err) {
    // Graceful fallback UI toast notification
    if (ss) {
      ss.toast('Selection Engine Notice: ' + err.message, 'System Route Alert', 6);
    }
    console.error('Fatal tracking failure in onSelectionChange: ' + err.stack);
  }
}
