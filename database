function saveUpdatedCaseEntry() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const entry = getUserEntrySheet_();

  if (!entry) {
    throw new Error('Missing entry sheet for current user');
  }

  try {
    const caseId = String(
      entry.getRange(SAVE_CASE_FIELD_MAP.currentCaseId).getDisplayValue() || ''
    ).trim();

    if (!caseId) {
      setSearchStatusSafe_(entry, 'Save failed: no loaded Case_ID');
      return;
    }

    setSearchStatusSafe_(entry, 'Saving updated case...');

    // ===================================
    // UPDATE CASES TABLE
    // ===================================
    const casesSheet = ss.getSheetByName('Cases');
    if (!casesSheet) throw new Error('Missing sheet: Cases');

    const headers = casesSheet
      .getRange(1, 1, 1, casesSheet.getLastColumn())
      .getValues()[0];

    const headerMap = getHeaderMap_(headers);

    const caseIdCol = headerMap['Case_ID'];
    if (caseIdCol === undefined) {
      throw new Error('Cases sheet missing Case_ID header');
    }

    // findRowByExactId_ expects a 1-based column number
    const rowNumber = findRowByExactId_(casesSheet, caseIdCol + 1, caseId);
    if (!rowNumber) {
      setSearchStatusSafe_(entry, 'Save failed: case not found in Cases');
      return;
    }

    const updateObj = readLoadedCaseForSave_(entry, caseId, headers);

    const existingRow = casesSheet
      .getRange(rowNumber, 1, 1, casesSheet.getLastColumn())
      .getValues()[0];

    auditChanges_('Cases', headers, existingRow, updateObj, caseId);
    writeObjectToRowByHeaders_(casesSheet, rowNumber, headers, updateObj);

    // ===================================
    // UPDATE SELECTED VICTIM
    // ===================================
    const victimsSheet = ss.getSheetByName('Victims');
    if (!victimsSheet) throw new Error('Missing sheet: Victims');

    const vData = victimsSheet.getDataRange().getValues();
    if (vData.length < 2) throw new Error('Victims sheet is empty');

    const vHeaders = vData[0];
    const vRows = vData.slice(1);
    const vh = getHeaderMap_(vHeaders);

    const caseCol = vh['Case_ID'];
    const victimIdCol = vh['Victim_ID'];

    if (caseCol === undefined || victimIdCol === undefined) {
      throw new Error('Victims sheet missing Case_ID or Victim_ID');
    }

    const selectedVictimRaw = String(
      entry.getRange(VICTIM_PICKER_CELL).getDisplayValue() || ''
    ).trim();

    const caseVictims = getVictimsByCaseId_(caseId);
    let selectedVictim = null;

    // Auto-resolve if only one victim
    if (caseVictims.length === 1) {
      selectedVictim = caseVictims[0];
    }
    // For multi-victim cases, only update victim row if a victim is selected
    else if (caseVictims.length > 1 && selectedVictimRaw) {
      selectedVictim = caseVictims.find(function(v) {
        return victimMatchesSelection_(v, selectedVictimRaw);
      }) || null;
    }

    if (selectedVictim) {
      const canonicalLabel = buildVictimDisplayLabel_(selectedVictim);
      if (selectedVictimRaw !== canonicalLabel) {
        entry.getRange(VICTIM_PICKER_CELL).setValue(canonicalLabel);
      }

      const selectedVictimId = String(
        selectedVictim.Victim_ID || selectedVictim['Victim ID'] || ''
      ).trim();

      let targetRow = -1;
      let existingVictimRow = null;

      for (let i = 0; i < vRows.length; i++) {
        const row = vRows[i];

        if (String(row[caseCol] || '').trim() !== caseId) continue;
        if (String(row[victimIdCol] || '').trim() !== selectedVictimId) continue;

        targetRow = i + 2; // sheet row number
        existingVictimRow = row;
        break;
      }

      if (targetRow !== -1 && existingVictimRow) {
        const updateVictim = {};

        setIfHeaderExists_(
          updateVictim,
          vHeaders,
          'Victim_First_Name',
          readEntryDisplay_(entry, SAVE_CASE_FIELD_MAP.Victim_First_Name)
