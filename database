/**
 * Normalise victim labels / IDs / names for matching.
 */
function normalizeVictimToken_(value) {
  return String(value || '')
    .trim()
    .toLowerCase()
    .replace(/\s+/g, ' ')
    .replace(/[–—]/g, '-')      // normalise dash types
    .replace(/\s*-\s*/g, ' - ');
}

/**
 * Build a stable victim display label for dropdowns / selectors.
 *
 * Preferred form:
 *   VIC0001 - Jane Doe
 *
 * Fallbacks:
 *   Jane Doe
 *   VIC0001
 */
function buildVictimDisplayLabel_(victimObj) {
  if (!victimObj) return '';

  const victimId = String(
    victimObj.Victim_ID ||
    victimObj['Victim ID'] ||
    ''
  ).trim();

  const first = String(
    victimObj.Victim_First_Name ||
