  ).trim();

  const alias = String(
    victimObj.Victim_Alias ||
    victimObj['Victim Alias'] ||
    victimObj.Victim_Alias_or_Known_As ||
    victimObj['Victim Alias or Known As'] ||
    ''
  ).trim();

  const victimName =
    String(victimObj.Victim || '').trim() ||
    buildVictimNameFromParts_(first, last, alias);

  if (victimId && victimName) return victimId + ' - ' + victimName;
  return victimId || victimName || '';
}

/**
 * True if a victim object matches the currently selected picker value.
 *
 * Supports matching by:
 * - Victim_ID
 * - display label (e.g. "VIC0001 - Jane Doe")
 * - victim name only
 * - loose contains match as final fallback
 */
function victimMatchesSelection_(victimObj, selectedRaw) {
  const raw = normalizeVictimToken_(selectedRaw);

  const victimId = normalizeVictimToken_(
    victimObj.Victim_ID || victimObj['Victim ID'] || ''
  );

  const first = String(
    victimObj.Victim_First_Name ||
    victimObj['Victim First Name'] ||
    ''
  ).trim();

  const last = String(
    victimObj.Victim_Last_Name ||
    victimObj['Victim Last Name'] ||
    ''
  ).trim();

  const alias = String(
    victimObj.Victim_Alias ||
    victimObj['Victim Alias'] ||
    victimObj.Victim_Alias_or_Known_As ||
    victimObj['Victim Alias or Known As'] ||
    ''
  ).trim();

  const victimName = normalizeVictimToken_(
    String(victimObj.Victim || '').trim() ||
    buildVictimNameFromParts_(first, last, alias)
  );

  const label = normalizeVictimToken_(buildVictimDisplayLabel_(victimObj));

  return (
    raw === victimId ||
    raw === victimName ||
    raw === label ||
    (victimId && raw.indexOf(victimId) !== -1) ||
    (victimName && raw.indexOf(victimName) !== -1)
  );
}

/**
 * Return all victim rows for a given Case_ID as objects.
 */
function getVictimsByCaseId_(caseId) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Victims');

  if (!sheet) throw new Error('Missing sheet: Victims');

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return [];

  const headers = data[0];
  const rows = data.slice(1);
  const headerMap = getHeaderMap_(headers);

  const caseIdCol = headerMap['Case_ID'];
  if (caseIdCol === undefined) {
    throw new Error('Victims sheet missing Case_ID column');
  }

  const wanted = String(caseId || '').trim();
  const victims = [];

  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    if (String(row[caseIdCol] || '').trim() !== wanted) continue;

    const victimObj = {};
    Object.keys(headerMap).forEach(function(key) {
      const colIndex = headerMap[key];
      victimObj[key] = row[colIndex];
    });

    victims.push(victimObj);
  }

  return victims;
}
/**
 * Return display-ready victim names for a given Case_ID.
 * This is useful for compact summaries / awareness text.
 */
function getVictimNamesByCaseId_(ss, caseId) {
  ss = ss || SpreadsheetApp.getActiveSpreadsheet();

  const victims = getVictimsByCaseId_(caseId);
  if (!victims || !victims.length) return [];

  const out = [];
  const seen = {};

  victims.forEach(function(v) {
    const victimName =
      String(v.Victim || '').trim() ||
      buildVictimNameFromParts_(
        v.Victim_First_Name || v['Victim First Name'] || '',
        v.Victim_Last_Name || v['Victim Last Name'] || '',
        v.Victim_Alias || v['Victim Alias'] || ''
      );

    if (!victimName) return;
    if (seen[victimName]) return;

    seen[victimName] = true;
    out.push(victimName);
  });

  return out;
}

/**
 * Compact string of victims for preview rows.
 * Example:
 *   "Jane Doe"
 *   "Jane Doe | John Smith"
 *   "Jane Doe | John Smith | +2 more"
 */
function getVictimsCompactString_(ss, caseId) {
  const names = getVictimNamesByCaseId_(ss, caseId);
  if (!names.length) return '';

  const MAX_VISIBLE = 2;
  if (names.length <= MAX_VISIBLE) {
    return names.join(' | ');
  }

  const visible = names.slice(0, MAX_VISIBLE);
  const remaining = names.length - MAX_VISIBLE;
  return visible.join(' | ') + ' | +' + remaining + ' more';
}
