    });

    // Save Prior Daily Mail Coverage if present
    try {
      savePriorDailyMailCoverage_(entry, caseId);
    } catch (coverageErr) {
      Logger.log('Prior Daily Mail Coverage save error: ' + coverageErr.message);
    }

    if (typeof safeAudit_ === 'function') {
      safeAudit_('CREATE_CASE', caseId, caseId);
    }

  setSearchStatusSafe_(
  entry,
  'New case saved ✅ ' + caseId +
  ' | Victim: ' + (relatedResult && relatedResult.victims != null ? relatedResult.victims : 0) +
  ' | Location: ' + (relatedResult && relatedResult.locations != null ? relatedResult.locations : 0) +
  ' | Source: ' + (relatedResult && relatedResult.sources != null ? relatedResult.sources : 0) +
  ' | Event: ' + (relatedResult && relatedResult.events != null ? relatedResult.events : 0) +
  ' | Image: ' + (relatedResult && relatedResult.images != null ? relatedResult.images : 0)
);


    return caseId;

  } catch (err) {
    setSearchStatusSafe_(entry, 'Save failed: ' + err.message);
    throw err;
  }
