function cfp_getFirstRowByCaseId_(sheetName, caseId) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) return null;

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return null;

  const headers = data[0].map(function(h) {
    return String(h || '').trim();
  });

  const idxCaseId = headers.indexOf('Case_ID');
  if (idxCaseId === -1) return null;

  for (let r = 1; r < data.length; r++) {
    if (String(data[r][idxCaseId] || '').trim() === String(caseId).trim()) {
      return cfp_rowObject_(headers, data[r]);
    }
  }

  return null;
}

function cfp_getLatestLiveEnquiryByCaseId_(caseId) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Case_Live_Enquiries');
  if (!sheet) return null;

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return null;

  const headers = data[0].map(function(h) {
    return String(h || '').trim();
  });

  const idxCaseId = headers.indexOf('Case_ID');
  if (idxCaseId === -1) return null;

  const matches = [];

  for (let r = 1; r < data.length; r++) {
    if (String(data[r][idxCaseId] || '').trim() === String(caseId).trim()) {
      matches.push(cfp_rowObject_(headers, data[r]));
    }
  }

  if (!matches.length) return null;

  matches.sort(function(a, b) {
    const da = cfp_toDate_(a['Enquiry_Date']);
    const db = cfp_toDate_(b['Enquiry_Date']);

    if (da && db) return db - da;
    if (db) return 1;
    if (da) return -1;
    return 0;
  });

  return matches[0];
}

function cfp_getFirstImageByCaseId_(caseId) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('Case_Images');
  if (!sheet) return null;

  const data = sheet.getDataRange().getValues();
  if (data.length < 2) return null;

  const headers = data[0].map(function(h) {
    return String(h || '').trim();
  });

  const idxCaseId = headers.indexOf('Case_ID');
  if (idxCaseId === -1) return null;

  for (let r = 1; r < data.length; r++) {
    if (String(data[r][idxCaseId] || '').trim() === String(caseId).trim()) {
      return cfp_rowObject_(headers, data[r]);
    }
  }

  return null;
}

function cfp_rowObject_(headers, rowValues) {
  const obj = {};
  headers.forEach(function(h, i) {
    obj[h] = rowValues[i];
  });
  return obj;
}

function cfp_getValue_(rowObj, possibleHeaders) {
  if (!rowObj) return '';

  for (let i = 0; i < possibleHeaders.length; i++) {
    const key = possibleHeaders[i];
    if (Object.prototype.hasOwnProperty.call(rowObj, key)) {
      return rowObj[key] !== undefined && rowObj[key] !== null ? rowObj[key] : '';
    }
  }

  return '';
}

function cfp_buildVictimDisplay_(victimRow) {
  if (!victimRow) return '';

  const directVictim = cfp_getValue_(victimRow, ['Victim']);
  const first = cfp_getValue_(victimRow, ['Victim_First_Name', 'First_Name', 'First Name']);
  const last = cfp_getValue_(victimRow, ['Victim_Last_Name', 'Last_Name', 'Last Name']);
  const alias = cfp_getValue_(victimRow, [
    'Victim_Alias_or_Known_As',
    'Victim_Alias',
    'Victim Alias',
    'Alias',
    'Known_As'
  ]);

  if (directVictim) return String(directVictim).trim();
  if (typeof buildVictimNameFromParts_ === 'function') {
    return buildVictimNameFromParts_(first, last, alias);
  }

  return cfp_joinParts_([first, last], ' ') || alias || '';
}

function cfp_joinParts_(parts, separator) {
  separator = separator || ' ';
  return parts
    .map(function(v) { return String(v || '').trim(); })
    .filter(function(v) { return v; })
    .join(separator);
}

function cfp_yesNo_(value) {
  return value === true || String(value).toUpperCase() === 'TRUE' ? 'Yes' : 'No';
}

function cfp_toDate_(value) {
  if (!value) return null;

  if (
    Object.prototype.toString.call(value) === '[object Date]' &&
    !isNaN(value.getTime())
  ) {
    return value;
  }

  const parsed = new Date(value);
  if (!isNaN(parsed.getTime())) return parsed;

  return null;
}

