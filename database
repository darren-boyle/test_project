/**
 * Find the row number for an exact ID match in a specific column.
 * idColIndex is 1-based because it is used directly with getRange().
 * Returns actual sheet row number, or null if not found.
 * @param {GoogleAppsScript.Spreadsheet.Sheet} sheet
 * @param {number} idColIndex
 * @param {any} idValue
 * @return {number|null}
 */
function findRowByExactId_(sheet, idColIndex, idValue) {
  if (!sheet || !idColIndex || idValue === undefined || idValue === null) return null;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return null;

  const values = sheet
    .getRange(2, idColIndex, lastRow - 1, 1)
    .getValues()
    .flat();

  const targetStr = String(idValue).trim();
  const index = values.findIndex(val => String(val).trim() === targetStr);

  return index !== -1 ? index + 2 : null;
}

