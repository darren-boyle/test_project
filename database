/**
 * Save image metadata from the entry sheet into Case_Images.
 *
 * Current form mapping:
 *   B75 = Image URL
 *   B76 = Caption
 *   B78 = Credit
 *   B79 = Image Type
 *   B80 = Public Source Only (checkbox)
 *
 * Returns:
 *   0 = nothing saved (no image URL)
 *   1 = row appended
 *   2 = existing row updated
 */
function saveCaseImages_(sheet, caseId, sourceId) {
  if (!sheet) throw new Error('saveCaseImages_: sheet is required.');
  if (!caseId) throw new Error('saveCaseImages_: caseId is required.');

  const ss = sheet.getParent();
  const imgSheet = ss.getSheetByName('Case_Images');
  if (!imgSheet) throw new Error('Missing sheet: Case_Images');

  const safeCaseId = String(caseId || '').trim();

  // Confirmed entry form mapping
  const imageUrl = String(sheet.getRange('B75').getDisplayValue() || '').trim();
  const caption = String(sheet.getRange('B76').getDisplayValue() || '').trim();
  const credit = String(sheet.getRange('B78').getDisplayValue() || '').trim();
  const imageType = String(sheet.getRange('B79').getDisplayValue() || '').trim();
  const publicSourceOnly = sheet.getRange('B80').getValue() === true;
  const notes = '';

  Logger.log('saveCaseImages_: START | sheet=' + sheet.getName() + ' | caseId=' + safeCaseId);
  Logger.log(
    'saveCaseImages_: PAYLOAD | imageUrl=' + imageUrl +
    ' | caption=' + caption +
    ' | credit=' + credit +
    ' | imageType=' + imageType +
    ' | publicSourceOnly=' + publicSourceOnly
  );

  if (!imageUrl) {
    Logger.log('saveCaseImages_: SKIP | no image URL in B75');
    return 0;
  }

  const data = imgSheet.getDataRange().getDisplayValues();
  if (data.length < 1) {
    throw new Error('Case_Images sheet is missing headers.');
  }

  const headers = data[0];
  const rows = data.slice(1);
  const headerMap = getHeaderMap_(headers);

  const idxCase = headerMap['Case_ID'];
  const idxUrl = headerMap['Image_URL'];

  if (idxCase === undefined || idxUrl === undefined) {
    throw new Error('Case_Images headers must include Case_ID and Image_URL.');
  }

  // If same Case_ID + Image_URL already exists, update that row
  for (let i = 0; i < rows.length; i++) {
    const rowCaseId = String(rows[i][idxCase] || '').trim();
    const rowUrl = String(rows[i][idxUrl] || '').trim();

    if (rowCaseId === safeCaseId && rowUrl === imageUrl) {
      const targetRow = i + 2; // header row + 1-based sheet rows

      updateCaseImageRow_(imgSheet, headers, headerMap, targetRow, {
        Case_ID: safeCaseId,
        Image_URL: imageUrl,
        Caption: caption,
        Credit: credit,
        Source_ID: sourceId || '',
        Image_Type: imageType || 'Victim',
        Public_Source_Only: publicSourceOnly,
        Notes: notes
      });

      Logger.log('saveCaseImages_: UPDATED existing row ' + targetRow + ' for Case_ID=' + safeCaseId);
      return 2;
    }
  }

  // Otherwise append a new row
  const imageId = getNextImageId_(imgSheet, headerMap);
  const rowObj = save_blankRowObject_(headers);

  setIfHeaderExists_(rowObj, headers, 'Image_ID', imageId);
  setIfHeaderExists_(rowObj, headers, 'Case_ID', safeCaseId);
  setIfHeaderExists_(rowObj, headers, 'Image_URL', imageUrl);
  setIfHeaderExists_(rowObj, headers, 'Caption', caption);
  setIfHeaderExists_(rowObj, headers, 'Credit', credit);
  setIfHeaderExists_(rowObj, headers, 'Source_ID', sourceId || '');
  setIfHeaderExists_(rowObj, headers, 'Image_Type', imageType || 'Victim');
  setIfHeaderExists_(rowObj, headers, 'Public_Source_Only', publicSourceOnly);
  setIfHeaderExists_(rowObj, headers, 'Notes', notes);

  save_appendObjectRowByHeaders_(imgSheet, headers, rowObj);

  Logger.log('saveCaseImages_: APPENDED new row for Case_ID=' + safeCaseId + ' with Image_ID=' + imageId);
  return 1;
}

/**
 * Update an existing row in Case_Images using header-aware mapping.
 */
function updateCaseImageRow_(sheet, headers, headerMap, rowNumber, updates) {
  if (!sheet) throw new Error('updateCaseImageRow_: sheet is required.');
  if (!headers || !headers.length) throw new Error('updateCaseImageRow_: headers are required.');
  if (!headerMap) throw new Error('updateCaseImageRow_: headerMap is required.');
  if (!rowNumber || rowNumber < 2) throw new Error('updateCaseImageRow_: valid rowNumber is required.');

  const existingRow = sheet.getRange(rowNumber, 1, 1, headers.length).getValues()[0];
  const newRow = existingRow.slice();

  Object.keys(updates || {}).forEach(function(header) {
    const idx = headerMap[header];
    if (idx !== undefined) {
      newRow[idx] = updates[header];
    }
  });

  sheet.getRange(rowNumber, 1, 1, headers.length).setValues([newRow]);
}
