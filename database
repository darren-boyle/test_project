        );

        writeObjectToRowByHeaders_(
          victimsSheet,
          targetRow,
          vHeaders,
          updateVictim
        );
      } else {
        setSearchStatusSafe_(entry, 'Warning: selected victim row not found for update');
      }
    }

    // ===================================
    // SAVE IMAGE TO CASE_IMAGES
    // ===================================
    const imageUrl = String(entry.getRange('B75').getValue() || '').trim();
    const caption = String(entry.getRange('B76').getValue() || '').trim();
    const credit = String(entry.getRange('B78').getValue() || '').trim();
    const imageType = String(entry.getRange('B79').getValue() || 'Victim').trim();
    const publicSource = entry.getRange('B80').getValue() === true;

    if (imageUrl) {
      const imagesSheet = ss.getSheetByName('Case_Images');
      if (!imagesSheet) throw new Error('Missing sheet: Case_Images');

      const iData = imagesSheet.getDataRange().getValues();
      if (iData.length < 1) throw new Error('Case_Images sheet is empty');

      const iHeaders = iData[0];
      const ih = getHeaderMap_(iHeaders);

      const imageCaseCol = ih['Case_ID'];
      const imageVictimCol = ih['Victim_ID'];
      const imageUrlCol = ih['Image_URL'];

      if (imageCaseCol === undefined || imageVictimCol === undefined || imageUrlCol === undefined) {
        throw new Error('Case_Images missing required columns');
      }

      const selectedVictimRawForImage = String(
