 *********************************/
function onEdit(e) {
  const props = PropertiesService.getDocumentProperties();
  const ONEDIT_RUNNING_PROP = 'ONEDIT_RUNNING';

  // Hard re-entry guard
  if (props.getProperty(ONEDIT_RUNNING_PROP) === 'true') {
    return;
  }

  // Existing flow guards
  if (
    props.getProperty(SEARCH_IS_CLEARING_PROP) === 'true' ||
    props.getProperty(SEARCH_IS_AUTO_LOADING_PROP) === 'true'
  ) {
    return;
  }

  try {
    props.setProperty(ONEDIT_RUNNING_PROP, 'true');

    if (!e || !e.range) return;

    const range = e.range;
    const sheet = range.getSheet();
    if (!sheet) return;

    const sheetName = String(sheet.getName() || '').trim();

    // Only respond on recognised entry sheets
    if (typeof search_getAllEntrySheetNames_ === 'function') {
      const validNames = search_getAllEntrySheetNames_();
      if (!Array.isArray(validNames) || validNames.indexOf(sheetName) === -1) {
        return;
      }
    }

    const row = range.getRow();
    const col = range.getColumn();

    // -----------------------------------------
    // Search box = merged G5:H5
    // -----------------------------------------
    const searchRange = sheet.getRange('G5:H5');
    const searchRow = searchRange.getRow();
    const searchCol = searchRange.getColumn();
    const searchWidth = searchRange.getNumColumns();

    if (
      row === searchRow &&
      col >= searchCol &&
      col < (searchCol + searchWidth)
    ) {
      const text = String(searchRange.getDisplayValue() || '').trim();

      if (!text) {
        if (typeof search_clearSearchOutputs_ === 'function') {
          search_clearSearchOutputs_(sheet);
        }
        return;
      }

      if (text.length < 3) {
        if (typeof search_setSearchStatusSafe_ === 'function') {
          search_setSearchStatusSafe_(sheet, 'Enter at least 3 characters');
        }
        return;
      }

      if (typeof runSearchCases === 'function') {
        runSearchCases(sheet);
      } else {
        throw new Error('runSearchCases is not defined');
      }

      return;
    }

    // -----------------------------------------
    // Selected case / victim picker
    // -----------------------------------------
    let pickerA1 = 'I11'; // safe fallback
    if (typeof search_getVictimPickerCellA1_ === 'function') {
      pickerA1 = search_getVictimPickerCellA1_();
    }

    const pickerCell = sheet.getRange(pickerA1);

    if (
      row === pickerCell.getRow() &&
      col === pickerCell.getColumn()
    ) {
      if (typeof handleSearchResultSelection_ === 'function') {
        handleSearchResultSelection_(e);
      } else if (typeof search_setSearchStatusSafe_ === 'function') {
        search_setSearchStatusSafe_(sheet, 'Victim selection handler missing');
      }
      return;
    }

  } catch (err) {
    try {
      // IMPORTANT:
      // Do NOT call search_getEntrySheetSafe_() here because if that helper
      // is part of a recursive loop, the catch block will recurse too.
      const entry = (e && e.range && e.range.getSheet) ? e.range.getSheet() : null;

      if (entry && typeof search_setSearchStatusSafe_ === 'function') {
        search_setSearchStatusSafe_(
          entry,
          'onEdit error: ' + (err && err.message ? err.message : err)
        );
      }
    } catch (nestedErr) {
      // ignore nested failures
    }
  } finally {
    props.deleteProperty(ONEDIT_RUNNING_PROP);
