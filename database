function isAllowedWriteCell_(a1) {
  if (typeof a1 !== 'string' || !a1.trim()) throw new Error(`Invalid A1 string reference: ${a1}`);

  const sh = getUserEntrySheet_();
  if (!sh) throw new Error('isAllowedWriteCell_: Sheet reference unavailable');

  const target = sh.getRange(a1);
  const targetRow = target.getRow();
  const targetCol = target.getColumn();

  // Combine arrays safely
  const allowedRanges = [...getUserEditableRanges_(), ...getScriptUiRanges_()];

  return allowedRanges.some(rangeA1 => {
    if (!rangeA1) return false;
    const r = sh.getRange(rangeA1);
    
    // Fallback logic check if global safeGetLastColumn_ doesn't exist
    const lastCol = (typeof safeGetLastColumn_ === 'function') 
      ? safeGetLastColumn_(r, 'range r') 
      : r.getLastColumn();

    return targetRow >= r.getRow() &&
           targetRow <= r.getLastRow() &&
           targetCol >= r.getColumn() &&
           targetCol <= lastCol;
  });
}
