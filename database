/**
 * Audit a sheet's headers against an expected list.
 *
 * Returns:
 * {
 *   sheetName: '',
 *   foundHeaders: [],
 *   missingHeaders: [],
 *   duplicateHeaders: [],
 *   headerMap: {}
 * }
 */
function auditSheetHeaders_(sheetName, expectedHeaders) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(sheetName);

  if (!sheet) {
    throw new Error('Missing sheet: ' + sheetName);
  }

  const lastCol = sheet.getLastColumn();
  if (lastCol < 1) {
    throw new Error('Sheet has no headers: ' + sheetName);
  }

  const headers = sheet
    .getRange(1, 1, 1, lastCol)
    .getDisplayValues()[0]
    .map(function(h) {
      return String(h || '').trim();
    });

  const headerMap = getHeaderMap_(headers);

  const missingHeaders = (expectedHeaders || []).filter(function(h) {
    return headerMap[h] === undefined;
  });

  const seen = {};
  const duplicateHeaders = [];

  headers.forEach(function(h) {
    if (!h) return;
    if (seen[h]) duplicateHeaders.push(h);
    seen[h] = true;
  });

  return {
    sheetName: sheetName,
    foundHeaders: headers,
    missingHeaders: missingHeaders,
    duplicateHeaders: duplicateHeaders,
    headerMap: headerMap
  };
}

/**
 * Format an auditSheetHeaders_ result into a readable text report.
 */
function formatHeaderAuditReport_(audit) {
  const lines = [];

  lines.push('Sheet: ' + audit.sheetName);
  lines.push('');

  if (audit.missingHeaders.length) {
    lines.push('Missing expected headers:');
    audit.missingHeaders.forEach(function(h) {
      lines.push(' - ' + h);
    });
  } else {
    lines.push('Missing expected headers: None ✅');
  }

  lines.push('');

  if (audit.duplicateHeaders.length) {
    lines.push('Duplicate headers found:');
    audit.duplicateHeaders.forEach(function(h) {
      lines.push(' - ' + h);
    });
  } else {
    lines.push('Duplicate headers found: None ✅');
  }

  lines.push('');
  lines.push('Found headers:');
  audit.foundHeaders.forEach(function(h) {
    lines.push(' - ' + h);
  });

  return lines.join('\n');
}

/**
 * Compare an old sheet row to a new object and log field-level changes.
 *
 * Notes:
 * - headers must be the header row array for the target sheet
 * - oldRow must be the existing row array from the sheet
 * - newObj is the incoming update object keyed by header name
 * - recordId is the record being updated
 */
function auditChanges_(sheetName, headers, oldRow, newObj, recordId) {
  const map = getHeaderMap_(headers);
  const entrySheet = getUserEntrySheet_();
  const sourceFormName = entrySheet ? entrySheet.getName() : 'Unknown entry sheet';

  Object.keys(newObj || {}).forEach(function(field) {
    const colIndex = map[field];
    if (colIndex === undefined) return;

    const oldValue = oldRow[colIndex];
    const newValue = newObj[field];

    if (String(oldValue) !== String(newValue)) {
      logAuditIfAvailable_({
        actionType: 'FIELD_UPDATE',
        recordId: recordId,
        fieldName: field,
        oldValue: oldValue,
        newValue: newValue,
        sourceForm: sourceFormName,
        sheetName: sheetName
      });
    }
  });
}

/**
 * Safe audit wrapper.
 *
 * Supports either:
 * 1) safeAudit_(sheetName, headers, oldRow, newObj, recordId)
 * 2) safeAudit_({
 *      sheetName: 'Cases',
 *      headers: headers,
 *      oldRow: oldRow,
 *      newObj: newObj,
 *      recordId: caseId
 *    })
 *
 * Never throws — logs and returns false if audit cannot be completed.
 */
function safeAudit_(arg1, arg2, arg3, arg4, arg5) {
  try {
    let sheetName, headers, oldRow, newObj, recordId;

    // Object-style call
    if (
      arg1 &&
      typeof arg1 === 'object' &&
      !Array.isArray(arg1)
    ) {
      sheetName = arg1.sheetName || arg1.sheet || '';
      headers = arg1.headers || [];
      oldRow = arg1.oldRow || [];
      newObj = arg1.newObj || arg1.values || {};
      recordId = arg1.recordId || arg1.id || '';
    } else {
      // Positional call
      sheetName = arg1 || '';
      headers = arg2 || [];
      oldRow = arg3 || [];
      newObj = arg4 || {};
      recordId = arg5 || '';
    }

    if (typeof auditChanges_ !== 'function') {
      Logger.log('safeAudit_: auditChanges_ is not available');
      return false;
    }

    if (!sheetName || !headers || !oldRow || !newObj) {
      Logger.log('safeAudit_: missing required audit inputs');
      return false;
    }

    auditChanges_(sheetName, headers, oldRow, newObj, recordId || '');
    return true;

  } catch (err) {
    Logger.log('safeAudit_ failed: ' + err);
    return false;
  }
}

/**
 * Safe audit log writer.
 * Appends to Audit_Log only if the sheet and expected headers exist.
 *
 * Expected payload keys:
 * - actionType
 * - recordId
 * - fieldName
 * - oldValue
 * - newValue
 * - sourceForm
 * - notes
 */
function logAuditIfAvailable_(entry) {
  try {
    const payload = entry || {};
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('Audit_Log');
    if (!sheet) return false;

    const lastCol = sheet.getLastColumn();
    if (lastCol < 1) return false;

    const headers = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0];
    const headerMap = getHeaderMap_(headers);
    const rowObj = save_blankRowObject_(headers);

    // Generate Log_ID safely if header exists
    if (headerMap['Log_ID'] !== undefined) {
      rowObj['Log_ID'] = save_nextIdByPrefix_(sheet, headerMap, 'Log_ID', 'LOG-');
    }

    setIfHeaderExists_(rowObj, headers, 'Timestamp', new Date());
    setIfHeaderExists_(rowObj, headers, 'User_Email', Session.getActiveUser().getEmail());
    setIfHeaderExists_(rowObj, headers, 'Action_Type', payload.actionType || payload.Action_Type || '');
    setIfHeaderExists_(rowObj, headers, 'Record_ID', payload.recordId || payload.Record_ID || '');
    setIfHeaderExists_(rowObj, headers, 'Field_Name', payload.fieldName || payload.Field_Name || '');
    setIfHeaderExists_(rowObj, headers, 'Old_Value', payload.oldValue || payload.Old_Value || '');
    setIfHeaderExists_(rowObj, headers, 'New_Value', payload.newValue || payload.New_Value || '');
    setIfHeaderExists_(rowObj, headers, 'Source_Form', payload.sourceForm || payload.Source_Form || '');
    setIfHeaderExists_(rowObj, headers, 'Notes', payload.notes || payload.Notes || '');

    save_appendObjectRowByHeaders_(sheet, headers, rowObj);
    return true;

  } catch (err) {
    Logger.log('logAuditIfAvailable_ failed: ' + err);
    return false;
  }
}
