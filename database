/**
 * Extract Daily Mail metadata from a story URL.
 *
 * Returns:
 * {
 *   storyCode: '',
 *   headlineSlug: ''
 * }
 */
function extractDailyMailMeta_(url) {
  const out = {
    storyCode: '',
    headlineSlug: ''
  };

  if (!url) return out;

  url = String(url).trim();

  const codeMatch = url.match(/article-(\d+)/i);
  if (codeMatch) {
    out.storyCode = codeMatch[1];
  }

  const slugMatch = url.match(/article-\d+\/([^/?#]+)\.html/i);
  if (slugMatch) {
    out.headlineSlug = slugMatch[1]
      .replace(/-/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  return out;
}

/**
 * Read prior Daily Mail coverage URLs from the entry sheet.
 *
 * Looks first in B48:B52 as separate rows.
 * If none are found, falls back to splitting B48 by line breaks.
 *
 * Returns a de-duplicated array of valid http/https URLs.
 */
function getPriorDailyMailCoverageUrls_(sheet) {
  if (!sheet) return [];

  let urls = [];

  const rangeValues = sheet.getRange('B48:B52').getDisplayValues().flat();

  rangeValues.forEach(function(v) {
    v = String(v || '').trim();
    if (v) urls.push(v);
  });

  if (!urls.length) {
    const mergedText = String(sheet.getRange('B48').getDisplayValue() || '').trim();
    if (mergedText) {
      mergedText
        .split(/\r?\n/)
        .map(function(line) {
          return String(line || '').trim();
        })
        .filter(function(line) {
          return line;
        })
        .forEach(function(line) {
          urls.push(line);
        });
    }
  }

  urls = urls.filter(function(u) {
    return /^https?:\/\//i.test(u);
  });

  const seen = {};
  urls = urls.filter(function(u) {
    const key = u.toLowerCase();
    if (seen[key]) return false;
    seen[key] = true;
    return true;
  });

  return urls;
}
/**
 * Build a Related_Stories row from a Daily Mail URL.
 *
 * Output columns:
 *   Story_Code
 *   Case_ID
 *   Publication
 *   Headline_Slug
 *   Story_URL
 *   Publish_Date
 *   Story_Type
 *   Notes
 */
function buildRelatedStoryRowFromUrl_(caseId, url) {
  if (!url) return null;

  url = String(url).trim();
  if (!url) return null;

  const meta = extractDailyMailMeta_(url);

  return [
    meta.storyCode || '',                              // Story_Code
    caseId || '',                                      // Case_ID
    'Daily Mail',                                      // Publication
    meta.headlineSlug || '',                           // Headline_Slug
    url,                                               // Story_URL
    '',                                                // Publish_Date
    'Prior Daily Mail Coverage',                       // Story_Type
    'Captured from Prior Daily Mail Coverage block'    // Notes
  ];
}

/**
 * Save prior Daily Mail coverage URLs from the entry sheet
 * into the Related_Stories sheet, avoiding duplicates.
 *
 * Duplicate rule:
 * - if Story_Code exists, match on Case_ID + Publication + Story_Code
 * - otherwise match on Case_ID + Publication + Story_URL
 *
 * Returns the number of rows appended.
 */
function savePriorDailyMailCoverage_(sheet, caseId) {
  if (!sheet) throw new Error('savePriorDailyMailCoverage_: sheet is required.');
  if (!caseId) throw new Error('savePriorDailyMailCoverage_: caseId is required.');

  const ss = sheet.getParent();
  const relatedSheet = ss.getSheetByName('Related_Stories');
  if (!relatedSheet) throw new Error('Related_Stories sheet not found.');

  const urls = getPriorDailyMailCoverageUrls_(sheet);
  if (!urls.length) return 0;

  const existing = relatedSheet.getDataRange().getValues();
  const rowsToAppend = [];

  for (let i = 0; i < urls.length; i++) {
    const url = String(urls[i]).trim();
    if (!url) continue;

    const row = buildRelatedStoryRowFromUrl_(caseId, url);
    if (!row) continue;

    const storyCode = String(row[0] || '').trim();
    const publication = String(row[2] || '').trim();
    const storyUrl = String(row[4] || '').trim();

    const isDuplicate = existing.some(function(r, idx) {
      if (idx === 0) return false;

      const existingStoryCode = String(r[0] || '').trim();
      const existingCaseId = String(r[1] || '').trim();
      const existingPublication = String(r[2] || '').trim();
      const existingStoryUrl = String(r[4] || '').trim();

      if (storyCode) {
        return (
          existingCaseId === String(caseId).trim() &&
          existingPublication === publication &&
          existingStoryCode === storyCode
        );
      }

      return (
        existingCaseId === String(caseId).trim() &&
        existingPublication === publication &&
        existingStoryUrl === storyUrl
      );
    });

    if (!isDuplicate) {
      rowsToAppend.push(row);
    }
  }

  if (rowsToAppend.length) {
    relatedSheet
      .getRange(
        relatedSheet.getLastRow() + 1,
        1,
        rowsToAppend.length,
        rowsToAppend[0].length
      )
      .setValues(rowsToAppend);
  }

  return rowsToAppend.length;
}
